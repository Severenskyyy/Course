<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    Отчёт "Просрочки" - Библиотека АБИС
    Конфигурация 1С:Предприятие 8.3
    
    Отчёт на СКД с полями:
    - reader_id, fio, group, book_code, title, author, days_overdue
    
    Показатели:
    - Доля просроченных выдач (% от всех активных)
    - Средняя/медианная просрочка (дни)
    - ТОП-N читателей/книг по просрочке
    
    Фильтры:
    - Период, группа читателя, автор/УДК, интервал просрочки
-->
<MetaDataObject xmlns="http://v8.1c.ru/8.3/MDClasses" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Report uuid="rep-overdue-001">
        <InternalInfo>
            <ObjectVersion>1.0.0</ObjectVersion>
            <GeneratedType>Report</GeneratedType>
        </InternalInfo>
        <Properties>
            <Name>Просрочки</Name>
            <Synonym>
                <v8:item>
                    <v8:lang>ru</v8:lang>
                    <v8:content>Отчёт о просрочках</v8:content>
                </v8:item>
            </Synonym>
            <Comment>Отчёт о просроченных выдачах книг согласно ТЗ</Comment>
            <UseStandardCommands>true</UseStandardCommands>
            <DefaultForm>Report.Просрочки.Form.ФормаОтчета</DefaultForm>
            <MainDataCompositionSchema>Report.Просрочки.Template.ОсновнаяСхемаКомпоновкиДанных</MainDataCompositionSchema>
        </Properties>
        
        <ChildObjects>
            <!-- Схема компоновки данных -->
            <Template uuid="tpl-main-001">
                <Properties>
                    <Name>ОсновнаяСхемаКомпоновкиДанных</Name>
                    <Synonym>
                        <v8:item>
                            <v8:lang>ru</v8:lang>
                            <v8:content>Основная схема компоновки данных</v8:content>
                        </v8:item>
                    </Synonym>
                    <TemplateType>DataCompositionSchema</TemplateType>
                </Properties>
                
                <!-- Содержимое СКД -->
                <DataCompositionSchema>
                    <DataSources>
                        <DataSource>
                            <Name>ИсточникДанных1</Name>
                            <DataSourceType>Local</DataSourceType>
                        </DataSource>
                    </DataSources>
                    
                    <DataSets>
                        <DataSet xsi:type="DataSetQuery">
                            <Name>НаборДанных1</Name>
                            <DataSource>ИсточникДанных1</DataSource>
                            <Query>
                                ВЫБРАТЬ
                                    Выдачи.Читатель.Код КАК reader_id,
                                    Выдачи.Читатель.Наименование КАК fio,
                                    Выдачи.Читатель.Группа КАК "group",
                                    Выдачи.Книга.Код КАК book_code,
                                    Выдачи.Книга.Наименование КАК title,
                                    Выдачи.Книга.Автор КАК author,
                                    Выдачи.Книга.УДК КАК udk,
                                    Выдачи.ДатаВыдачи КАК issue_date,
                                    Выдачи.ДатаВозвратаПлан КАК due_date,
                                    Выдачи.ДатаВозврата КАК return_date,
                                    ВЫБОР
                                        КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
                                            ТОГДА РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, &amp;ТекущаяДата, ДЕНЬ)
                                        ИНАЧЕ РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, Выдачи.ДатаВозврата, ДЕНЬ)
                                    КОНЕЦ КАК days_overdue,
                                    ВЫБОР
                                        КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
                                            ТОГДА "Активная просрочка"
                                        ИНАЧЕ "Возвращена с просрочкой"
                                    КОНЕЦ КАК status
                                ИЗ
                                    РегистрНакопления.Выдачи КАК Выдачи
                                ГДЕ
                                    (Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозвратаПлан &lt; &amp;ТекущаяДата)
                                    ИЛИ (Выдачи.ДатаВозврата &lt;&gt; ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозврата &gt; Выдачи.ДатаВозвратаПлан)
                                {ГДЕ
                                    (Выдачи.Читатель.Группа = &amp;Группа),
                                    (Выдачи.Книга.Автор = &amp;Автор),
                                    (Выдачи.Книга.УДК ПОДОБНО &amp;УДК),
                                    (days_overdue &gt;= &amp;МинДней),
                                    (days_overdue &lt;= &amp;МаксДней),
                                    (Выдачи.ДатаВыдачи &gt;= &amp;НачалоПериода),
                                    (Выдачи.ДатаВыдачи &lt;= &amp;КонецПериода)
                                }
                                УПОРЯДОЧИТЬ ПО
                                    days_overdue УБЫВ
                            </Query>
                            
                            <Fields>
                                <Field>
                                    <DataPath>reader_id</DataPath>
                                    <Title>ID читателя</Title>
                                </Field>
                                <Field>
                                    <DataPath>fio</DataPath>
                                    <Title>ФИО</Title>
                                </Field>
                                <Field>
                                    <DataPath>group</DataPath>
                                    <Title>Группа</Title>
                                </Field>
                                <Field>
                                    <DataPath>book_code</DataPath>
                                    <Title>Код книги</Title>
                                </Field>
                                <Field>
                                    <DataPath>title</DataPath>
                                    <Title>Название</Title>
                                </Field>
                                <Field>
                                    <DataPath>author</DataPath>
                                    <Title>Автор</Title>
                                </Field>
                                <Field>
                                    <DataPath>udk</DataPath>
                                    <Title>УДК</Title>
                                </Field>
                                <Field>
                                    <DataPath>issue_date</DataPath>
                                    <Title>Дата выдачи</Title>
                                </Field>
                                <Field>
                                    <DataPath>due_date</DataPath>
                                    <Title>Срок возврата</Title>
                                </Field>
                                <Field>
                                    <DataPath>return_date</DataPath>
                                    <Title>Дата возврата</Title>
                                </Field>
                                <Field>
                                    <DataPath>days_overdue</DataPath>
                                    <Title>Дней просрочки</Title>
                                </Field>
                                <Field>
                                    <DataPath>status</DataPath>
                                    <Title>Статус</Title>
                                </Field>
                            </Fields>
                        </DataSet>
                    </DataSets>
                    
                    <Parameters>
                        <Parameter>
                            <Name>ТекущаяДата</Name>
                            <Title>Текущая дата</Title>
                            <ValueType>
                                <Type>xs:dateTime</Type>
                                <DateQualifiers>
                                    <DateFractions>Date</DateFractions>
                                </DateQualifiers>
                            </ValueType>
                            <Value>НачалоДня(ТекущаяДата())</Value>
                            <DenyIncompleteValues>true</DenyIncompleteValues>
                        </Parameter>
                        <Parameter>
                            <Name>Группа</Name>
                            <Title>Группа читателя</Title>
                            <ValueType>
                                <Type>xs:string</Type>
                            </ValueType>
                            <UseRestriction>true</UseRestriction>
                        </Parameter>
                        <Parameter>
                            <Name>Автор</Name>
                            <Title>Автор книги</Title>
                            <ValueType>
                                <Type>xs:string</Type>
                            </ValueType>
                            <UseRestriction>true</UseRestriction>
                        </Parameter>
                        <Parameter>
                            <Name>УДК</Name>
                            <Title>УДК</Title>
                            <ValueType>
                                <Type>xs:string</Type>
                            </ValueType>
                            <UseRestriction>true</UseRestriction>
                        </Parameter>
                        <Parameter>
                            <Name>МинДней</Name>
                            <Title>Минимум дней просрочки</Title>
                            <ValueType>
                                <Type>xs:decimal</Type>
                            </ValueType>
                            <UseRestriction>true</UseRestriction>
                        </Parameter>
                        <Parameter>
                            <Name>МаксДней</Name>
                            <Title>Максимум дней просрочки</Title>
                            <ValueType>
                                <Type>xs:decimal</Type>
                            </ValueType>
                            <UseRestriction>true</UseRestriction>
                        </Parameter>
                        <Parameter>
                            <Name>НачалоПериода</Name>
                            <Title>Начало периода</Title>
                            <ValueType>
                                <Type>xs:dateTime</Type>
                            </ValueType>
                            <UseRestriction>true</UseRestriction>
                        </Parameter>
                        <Parameter>
                            <Name>КонецПериода</Name>
                            <Title>Конец периода</Title>
                            <ValueType>
                                <Type>xs:dateTime</Type>
                            </ValueType>
                            <UseRestriction>true</UseRestriction>
                        </Parameter>
                    </Parameters>
                    
                    <TotalFields>
                        <TotalField>
                            <DataPath>days_overdue</DataPath>
                            <Expression>Среднее(days_overdue)</Expression>
                            <Title>Средняя просрочка</Title>
                        </TotalField>
                        <TotalField>
                            <DataPath>reader_id</DataPath>
                            <Expression>Количество(РАЗЛИЧНЫЕ reader_id)</Expression>
                            <Title>Читателей с просрочками</Title>
                        </TotalField>
                        <TotalField>
                            <DataPath>book_code</DataPath>
                            <Expression>Количество(book_code)</Expression>
                            <Title>Всего просрочек</Title>
                        </TotalField>
                    </TotalFields>
                </DataCompositionSchema>
            </Template>
        </ChildObjects>
    </Report>
</MetaDataObject>
