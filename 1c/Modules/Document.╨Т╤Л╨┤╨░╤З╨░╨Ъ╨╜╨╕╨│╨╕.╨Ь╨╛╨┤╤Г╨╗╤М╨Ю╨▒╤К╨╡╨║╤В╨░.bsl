///////////////////////////////////////////////////////////////////////////////
// МОДУЛЬ ОБЪЕКТА: Документ.ВыдачаКниги
// Библиотека АБИС — обработка проведения и валидации бизнес-правил Кейса 8
//
// Проверки согласно ТЗ:
//   BR-01: одна активная выдача на book_code
//   BR-02: issue_date <= due_date
//   BR-03: reader_id существует
//   BR-04: book_code существует
//   BR-06: читатель не заблокирован
///////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытий

// Событие: ОбработкаПроведения
//
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    
    // BR-02: контроль дат
    ПроверкаДат = ОбщегоНазначения.ПроверитьДатыВыдачи(Дата, ПлановаяДатаВозврата);
    Если НЕ ПроверкаДат.Валидно Тогда
        Для Каждого Ошибка Из ПроверкаДат.Ошибки Цикл
            Сообщить(Ошибка);
        КонецЦикла;
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // BR-03: читатель существует
    Если НЕ ЗначениеЗаполнено(Читатель) Тогда
        Сообщить("BR-03: не указан читатель");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // BR-06: читатель не заблокирован
    Если Читатель.ЗаблокированВыдачи Тогда
        Сообщить("BR-06: читатель '" + Читатель.ФИО + "' заблокирован для выдач");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // BR-04: книга существует
    Если НЕ ЗначениеЗаполнено(Книга) Тогда
        Сообщить("BR-04: не указана книга");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // BR-01: одна активная выдача на book_code
    Если НЕ РаботаСКнигами.КнигаДоступна(Книга) Тогда
        Сообщить("BR-01: по книге '" + Книга + "' уже есть активная выдача");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Записываем движение по регистру "Выдачи"
    Движения.Выдачи.Записывать = Истина;
    Движение = Движения.Выдачи.ДобавитьПриход();
    Движение.Период = Дата;
    Движение.Книга = Книга;
    Движение.Читатель = Читатель;
    Движение.Количество = 1;
    Движение.ДокументВыдачи = Ссылка;
    Движение.ПлановаяДатаВозврата = ПлановаяДатаВозврата;
    
    ОбщегоНазначения.ЗаписатьВЖурнал("Выдача.Проведение",
        УровеньЖурналаРегистрации.Информация,
        "Выдача " + Номер + ": " + Книга + " -> " + Читатель);
    
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
    // Автозаполнение плановой даты возврата (14 дней по умолчанию)
    Если НЕ ЗначениеЗаполнено(ПлановаяДатаВозврата) И ЗначениеЗаполнено(Дата) Тогда
        ПлановаяДатаВозврата = Дата + 14 * 86400;
    КонецЕсли;
    
    // Автозаполнение Библиотекаря
    Если НЕ ЗначениеЗаполнено(Библиотекарь) Тогда
        Библиотекарь = ПараметрыСеанса.ТекущийПользователь;
    КонецЕсли;
    
КонецПроцедуры

#КонецОбласти
