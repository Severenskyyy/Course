///////////////////////////////////////////////////////////////////////////////
// ОБРАБОТКА: ЭкспортПросрочек
// Библиотека АБИС — экспорт отчёта "Просрочки" в CSV (обязательное требование ТЗ)
//
// Критерий приёмки Кейса 8, п.3: экспорт отчёта в CSV.
// Обязательные поля: reader_id, book_code, days_overdue
// Рекомендованные:   fio, title, issue_date, due_date
//
// Автор:   команда курса ОПД, РТУ МИРЭА
// Версия:  1.0.0
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Выполняет экспорт просрочек в CSV.
//
// Параметры:
//   ПутьКФайлу   - Строка - путь для сохранения CSV.
//   ДатаОценки   - Дата   - дата оценки просрочки; по умолчанию сегодня.
//   ФильтрГруппа - Строка - опциональный фильтр по группе читателя.
//
// Возвращаемое значение:
//   Структура: ЗаписейЭкспортировано, ОшибокЗаписи.
//
Функция ЭкспортироватьВCSV(ПутьКФайлу, ДатаОценки = Неопределено, ФильтрГруппа = "") Экспорт
    
    Если НЕ ЗначениеЗаполнено(ДатаОценки) Тогда
        ДатаОценки = ОбщегоНазначения.ТекущаяДатаБезВремени();
    КонецЕсли;
    
    Результат = Новый Структура("ЗаписейЭкспортировано, ОшибокЗаписи", 0, 0);
    
    Запись = Новый ЗаписьТекста(ПутьКФайлу, КодировкаТекста.UTF8);
    // Заголовок CSV
    Запись.ЗаписатьСтроку("reader_id;fio;group_name;book_code;title;issue_date;due_date;days_overdue");
    
    // Выбираем активные просроченные выдачи
    Запрос = Новый Запрос(
    "ВЫБРАТЬ
    |    Выдача.Читатель.Код           КАК ReaderId,
    |    Выдача.Читатель.ФИО           КАК FIO,
    |    Выдача.Читатель.Группа        КАК GroupName,
    |    Выдача.Книга.Код              КАК BookCode,
    |    Выдача.Книга.Наименование     КАК Title,
    |    Выдача.Дата                   КАК IssueDate,
    |    Выдача.ПлановаяДатаВозврата   КАК DueDate,
    |    Выдача.Ссылка                 КАК СсылкаВыдачи
    |ИЗ
    |    Документ.ВыдачаКниги КАК Выдача
    |ГДЕ
    |    Выдача.Проведен
    |    И &ДатаОценки > Выдача.ПлановаяДатаВозврата
    |    И НЕ Выдача.Ссылка В (ВЫБРАТЬ Возврат.ДокументВыдачи ИЗ Документ.ВозвратКниги КАК Возврат ГДЕ Возврат.Проведен)
    |    И (&ФильтрГруппаПусто ИЛИ Выдача.Читатель.Группа = &ФильтрГруппа)");
    
    Запрос.УстановитьПараметр("ДатаОценки", ДатаОценки);
    Запрос.УстановитьПараметр("ФильтрГруппа", ФильтрГруппа);
    Запрос.УстановитьПараметр("ФильтрГруппаПусто", ПустаяСтрока(ФильтрГруппа));
    
    Выборка = Запрос.Выполнить().Выбрать();
    
    Пока Выборка.Следующий() Цикл
        Попытка
            DaysOverdue = ОбщегоНазначения.РассчитатьДниПросрочки(
                Выборка.IssueDate, Выборка.DueDate, Дата(1,1,1), ДатаОценки);
            
            Строка = СтрШаблон("%1;%2;%3;%4;%5;%6;%7;%8",
                Выборка.ReaderId,
                ЭкранироватьПоле(Выборка.FIO),
                ЭкранироватьПоле(Выборка.GroupName),
                Выборка.BookCode,
                ЭкранироватьПоле(Выборка.Title),
                ОбщегоНазначения.ДатаВISO(Выборка.IssueDate),
                ОбщегоНазначения.ДатаВISO(Выборка.DueDate),
                DaysOverdue);
            Запись.ЗаписатьСтроку(Строка);
            Результат.ЗаписейЭкспортировано = Результат.ЗаписейЭкспортировано + 1;
        Исключение
            Результат.ОшибокЗаписи = Результат.ОшибокЗаписи + 1;
            ОбщегоНазначения.ЗаписатьВЖурнал("ЭкспортПросрочек.Ошибка",
                УровеньЖурналаРегистрации.Ошибка,
                ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;
    
    Запись.Закрыть();
    
    ОбщегоНазначения.ЗаписатьВЖурнал("ЭкспортПросрочек.Готово",
        УровеньЖурналаРегистрации.Информация,
        СтрШаблон("Экспортировано: %1, ошибок: %2 в файл %3",
            Результат.ЗаписейЭкспортировано, Результат.ОшибокЗаписи, ПутьКФайлу));
    
    Возврат Результат;
    
КонецФункции

// Экспорт агрегированных KPI просрочек в JSON (для обмена с FastAPI).
//
Функция ПолучитьKPIПросрочек(ДатаОценки = Неопределено) Экспорт
    
    Если НЕ ЗначениеЗаполнено(ДатаОценки) Тогда
        ДатаОценки = ОбщегоНазначения.ТекущаяДатаБезВремени();
    КонецЕсли;
    
    KPI = Новый Структура;
    KPI.Вставить("ДатаОценки", ОбщегоНазначения.ДатаВISO(ДатаОценки));
    
    // Активные выдачи = проведённые ВыдачаКниги без связанного проведённого ВозвратКниги
    ЗапросВсего = Новый Запрос(
    "ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Кол ИЗ Документ.ВыдачаКниги КАК В
    |ГДЕ В.Проведен
    |  И НЕ В.Ссылка В (ВЫБРАТЬ Возврат.ДокументВыдачи ИЗ Документ.ВозвратКниги КАК Возврат ГДЕ Возврат.Проведен)");
    ВсегоАктивных = ЗапросВсего.Выполнить().Выбрать();
    ВсегоАктивных.Следующий();
    KPI.Вставить("ВсегоАктивных", ВсегоАктивных.Кол);
    
    ЗапросПросрочки = Новый Запрос(
    "ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Кол ИЗ Документ.ВыдачаКниги КАК В
    |ГДЕ В.Проведен
    |  И &ДатаОценки > В.ПлановаяДатаВозврата
    |  И НЕ В.Ссылка В (ВЫБРАТЬ Возврат.ДокументВыдачи ИЗ Документ.ВозвратКниги КАК Возврат ГДЕ Возврат.Проведен)");
    ЗапросПросрочки.УстановитьПараметр("ДатаОценки", ДатаОценки);
    Просрочек = ЗапросПросрочки.Выполнить().Выбрать();
    Просрочек.Следующий();
    KPI.Вставить("ПросрочекКоличество", Просрочек.Кол);
    
    KPI.Вставить("ДоляПросрочек",
        ?(KPI.ВсегоАктивных = 0, 0, KPI.ПросрочекКоличество / KPI.ВсегоАктивных));
    
    Возврат KPI;
    
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЭкранироватьПоле(Значение)
    Стр = Строка(Значение);
    Стр = СтрЗаменить(Стр, ";", ",");  // разделитель безопасности
    Стр = СтрЗаменить(Стр, Символы.ПС, " ");
    Стр = СтрЗаменить(Стр, Символы.ВК, " ");
    Возврат Стр;
КонецФункции

#КонецОбласти
