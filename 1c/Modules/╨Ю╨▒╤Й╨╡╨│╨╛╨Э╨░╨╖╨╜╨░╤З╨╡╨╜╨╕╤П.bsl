#Область ПрограммныйИнтерфейс

// Возвращает текущую дату без времени (начало дня).
//
// Возвращаемое значение:
//   Дата — начало текущих суток.
//
Функция ТекущаяДатаБезВремени() Экспорт
    Возврат НачалоДня(ТекущаяДата());
КонецФункции

// Рассчитывает число дней просрочки согласно ТЗ Кейса 8.
// Просрочка: return_date = NULL и today > due_date,
//            или return_date > due_date.
//
// Параметры:
//   ДатаВыдачи         - Дата    - issue_date.
//   ПлановаяДата       - Дата    - due_date (целевая дата возврата).
//   ФактическаяДата    - Дата    - return_date, может быть пустой.
//   ДатаОценки         - Дата    - дата, на которую считаем (today); по умолчанию — текущая.
//
// Возвращаемое значение:
//   Число — количество дней просрочки (0 если просрочки нет).
//
Функция РассчитатьДниПросрочки(ДатаВыдачи, ПлановаяДата, ФактическаяДата, ДатаОценки = Неопределено) Экспорт
    
    Если НЕ ЗначениеЗаполнено(ДатаОценки) Тогда
        ДатаОценки = ТекущаяДатаБезВремени();
    КонецЕсли;
    
    Если ЗначениеЗаполнено(ФактическаяДата) Тогда
        // Книга уже возвращена — просрочка считается от разницы факт/план
        Если ФактическаяДата > ПлановаяДата Тогда
            Возврат Цел((ФактическаяДата - ПлановаяДата) / 86400);
        Иначе
            Возврат 0;
        КонецЕсли;
    Иначе
        // Книга не возвращена — смотрим, истёк ли срок
        Если ДатаОценки > ПлановаяДата Тогда
            Возврат Цел((ДатаОценки - ПлановаяДата) / 86400);
        Иначе
            Возврат 0;
        КонецЕсли;
    КонецЕсли;
    
КонецФункции

// Проверяет корректность триплета дат по ТЗ:
//   issue_date <= due_date; если return_date задана — due_date <= return_date.
//
// Параметры:
//   ДатаВыдачи      - Дата.
//   ПлановаяДата    - Дата.
//   ФактическаяДата - Дата / Неопределено.
//
// Возвращаемое значение:
//   Структура: Валидно (Булево), Ошибки (Массив строк).
//
Функция ПроверитьДатыВыдачи(ДатаВыдачи, ПлановаяДата, ФактическаяДата = Неопределено) Экспорт
    
    Результат = Новый Структура("Валидно, Ошибки", Истина, Новый Массив);
    
    Если НЕ ЗначениеЗаполнено(ДатаВыдачи) Тогда
        Результат.Ошибки.Добавить("Не указана дата выдачи");
        Результат.Валидно = Ложь;
    КонецЕсли;
    
    Если НЕ ЗначениеЗаполнено(ПлановаяДата) Тогда
        Результат.Ошибки.Добавить("Не указана плановая дата возврата");
        Результат.Валидно = Ложь;
    КонецЕсли;
    
    Если Результат.Валидно И ДатаВыдачи > ПлановаяДата Тогда
        Результат.Ошибки.Добавить("Дата выдачи позже плановой даты возврата (issue_date > due_date)");
        Результат.Валидно = Ложь;
    КонецЕсли;
    
    Если ЗначениеЗаполнено(ФактическаяДата) И ПлановаяДата > ФактическаяДата И ДатаВыдачи > ФактическаяДата Тогда
        // Контроль логической согласованности: фактический возврат не может быть раньше выдачи
        Если ФактическаяДата < ДатаВыдачи Тогда
            Результат.Ошибки.Добавить("Фактическая дата возврата раньше даты выдачи");
            Результат.Валидно = Ложь;
        КонецЕсли;
    КонецЕсли;
    
    Возврат Результат;
    
КонецФункции

// Вычисляет хеш-ключ для идемпотентного импорта CSV (SHA1 строки).
//
// Параметры:
//   Источник - Строка - произвольная строка для хеширования.
//
// Возвращаемое значение:
//   Строка — шестнадцатеричное представление хеша.
//
Функция ВычислитьХеш(Источник) Экспорт
    ХешированиеДанных = Новый ХешированиеДанных(ХешФункция.SHA1);
    ХешированиеДанных.Добавить(Источник);
    Возврат Строка(ХешированиеДанных.ХешСумма);
КонецФункции

// Форматирует дату в ISO 8601 (YYYY-MM-DD) — для обмена с FastAPI.
//
Функция ДатаВISO(Дата) Экспорт
    Если НЕ ЗначениеЗаполнено(Дата) Тогда
        Возврат "";
    КонецЕсли;
    Возврат Формат(Дата, "ДФ=yyyy-MM-dd");
КонецФункции

// Парсит ISO-дату в Дату 1С.
//
Функция ISOВДату(Строка) Экспорт
    Если ПустаяСтрока(Строка) ИЛИ Строка = "null" Тогда
        Возврат Дата(1,1,1);
    КонецЕсли;
    // Формат: YYYY-MM-DD [ или YYYY-MM-DDTHH:MM:SS ]
    ЧастьДаты = Лев(Строка, 10);
    Год  = Число(Сред(ЧастьДаты, 1, 4));
    Месяц = Число(Сред(ЧастьДаты, 6, 2));
    День  = Число(Сред(ЧастьДаты, 9, 2));
    Возврат Дата(Год, Месяц, День);
КонецФункции

// Возвращает код ошибки по бизнес-правилу (унифицировано с backend-слоем).
//
Функция КодОшибки(ИмяПравила) Экспорт
    Соответствие = Новый Соответствие;
    Соответствие.Вставить("КНИГА_УЖЕ_ВЫДАНА",   "BR-01");
    Соответствие.Вставить("НЕВЕРНЫЕ_ДАТЫ",       "BR-02");
    Соответствие.Вставить("НЕИЗВЕСТНЫЙ_ЧИТАТЕЛЬ", "BR-03");
    Соответствие.Вставить("НЕИЗВЕСТНАЯ_КНИГА",    "BR-04");
    Соответствие.Вставить("ВОЗВРАТ_БЕЗ_ВЫДАЧИ",   "BR-05");
    Соответствие.Вставить("ЧИТАТЕЛЬ_ЗАБЛОКИРОВАН", "BR-06");
    Возврат Соответствие.Получить(ИмяПравила);
КонецФункции

// Пишет структурированную запись в журнал регистрации.
//
Процедура ЗаписатьВЖурнал(Событие, Уровень, Сообщение, Данные = Неопределено) Экспорт
    ЗаписьЖурналаРегистрации(
        "АБИС." + Событие,
        Уровень,
        ,
        Данные,
        Сообщение);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Внутренний хелпер: читаемое представление книги/читателя для сообщений.
//
Функция ПредставлениеСсылки(Ссылка) Экспорт
    Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
        Возврат "<не задано>";
    КонецЕсли;
    Возврат Строка(Ссылка);
КонецФункции

#КонецОбласти
