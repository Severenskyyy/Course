#Область ПрограммныйИнтерфейс

// Импортирует справочник книг из CSV.
//
// Параметры:
//   ПутьКФайлу - Строка - полный путь к books.csv
//                        Формат: book_code;title;author;year;udk
//
// Возвращаемое значение:
//   Структура: Создано, Обновлено, Пропущено, Ошибок, Сообщения (Массив).
//
Функция ИмпортироватьКниги(ПутьКФайлу) Экспорт
    
    Результат = Новый Структура("Создано, Обновлено, Пропущено, Ошибок, Сообщения",
        0, 0, 0, 0, Новый Массив);
    
    ОбщегоНазначения.ЗаписатьВЖурнал("ИмпортКниг.Старт",
        УровеньЖурналаРегистрации.Информация,
        "Импорт из файла: " + ПутьКФайлу);
    
    Чтение = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8);
    // Пропускаем заголовок
    Заголовок = Чтение.ПрочитатьСтроку();
    
    НомерСтроки = 1;
    Пока Истина Цикл
        Строка = Чтение.ПрочитатьСтроку();
        Если Строка = Неопределено Тогда
            Прервать;
        КонецЕсли;
        НомерСтроки = НомерСтроки + 1;
        
        Если ПустаяСтрока(Строка) Тогда
            Продолжить;
        КонецЕсли;
        
        Поля = СтрРазделить(Строка, ";", Истина);
        Если Поля.Количество() < 5 Тогда
            Результат.Ошибок = Результат.Ошибок + 1;
            Результат.Сообщения.Добавить("Строка " + НомерСтроки + ": недостаточно полей");
            Продолжить;
        КонецЕсли;
        
        BookCode = СокрЛП(Поля[0]);
        Title    = СокрЛП(Поля[1]);
        Author   = СокрЛП(Поля[2]);
        Year     = Число(СокрЛП(Поля[3]));
        UDK      = СокрЛП(Поля[4]);
        
        Попытка
            Ссылка = НайтиИлиСоздатьКнигу(BookCode, Title, Author, Year, UDK, Результат);
        Исключение
            Результат.Ошибок = Результат.Ошибок + 1;
            Результат.Сообщения.Добавить("Строка " + НомерСтроки + ": " + ОписаниеОшибки());
        КонецПопытки;
        
    КонецЦикла;
    
    Чтение.Закрыть();
    
    ОбщегоНазначения.ЗаписатьВЖурнал("ИмпортКниг.Финиш",
        УровеньЖурналаРегистрации.Информация,
        СтрШаблон("Создано:%1 Обновлено:%2 Пропущено:%3 Ошибок:%4",
            Результат.Создано, Результат.Обновлено, Результат.Пропущено, Результат.Ошибок));
    
    Возврат Результат;
    
КонецФункции

// Импортирует справочник читателей из CSV.
// Формат: reader_id;fio;group
//
Функция ИмпортироватьЧитателей(ПутьКФайлу) Экспорт
    
    Результат = Новый Структура("Создано, Обновлено, Пропущено, Ошибок, Сообщения",
        0, 0, 0, 0, Новый Массив);
    
    Чтение = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8);
    Чтение.ПрочитатьСтроку(); // skip header
    
    НомерСтроки = 1;
    Пока Истина Цикл
        Строка = Чтение.ПрочитатьСтроку();
        Если Строка = Неопределено Тогда
            Прервать;
        КонецЕсли;
        НомерСтроки = НомерСтроки + 1;
        
        Если ПустаяСтрока(Строка) Тогда
            Продолжить;
        КонецЕсли;
        
        Поля = СтрРазделить(Строка, ";", Истина);
        Если Поля.Количество() < 3 Тогда
            Результат.Ошибок = Результат.Ошибок + 1;
            Продолжить;
        КонецЕсли;
        
        Попытка
            НайтиИлиСоздатьЧитателя(СокрЛП(Поля[0]), СокрЛП(Поля[1]), СокрЛП(Поля[2]), Результат);
        Исключение
            Результат.Ошибок = Результат.Ошибок + 1;
            Результат.Сообщения.Добавить("Строка " + НомерСтроки + ": " + ОписаниеОшибки());
        КонецПопытки;
        
    КонецЦикла;
    
    Чтение.Закрыть();
    Возврат Результат;
    
КонецФункции

// Импортирует выдачи из CSV — идемпотентно по loan_id.
// Формат: loan_id;reader_id;book_code;issue_date;due_date;return_date
//
Функция ИмпортироватьВыдачи(ПутьКФайлу) Экспорт
    
    Результат = Новый Структура("Создано, Обновлено, Пропущено, Ошибок, Сообщения",
        0, 0, 0, 0, Новый Массив);
    
    Чтение = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8);
    Чтение.ПрочитатьСтроку(); // skip header
    
    НомерСтроки = 1;
    Пока Истина Цикл
        Строка = Чтение.ПрочитатьСтроку();
        Если Строка = Неопределено Тогда
            Прервать;
        КонецЕсли;
        НомерСтроки = НомерСтроки + 1;
        
        Если ПустаяСтрока(Строка) Тогда
            Продолжить;
        КонецЕсли;
        
        Поля = СтрРазделить(Строка, ";", Истина);
        Если Поля.Количество() < 5 Тогда
            Результат.Ошибок = Результат.Ошибок + 1;
            Продолжить;
        КонецЕсли;
        
        LoanId    = СокрЛП(Поля[0]);
        ReaderId  = СокрЛП(Поля[1]);
        BookCode  = СокрЛП(Поля[2]);
        IssueDate = ОбщегоНазначения.ISOВДату(СокрЛП(Поля[3]));
        DueDate   = ОбщегоНазначения.ISOВДату(СокрЛП(Поля[4]));
        ReturnDate = ?(Поля.Количество() >= 6,
            ОбщегоНазначения.ISOВДату(СокрЛП(Поля[5])),
            Дата(1,1,1));
        
        Попытка
            ИмпортОднойВыдачи(LoanId, ReaderId, BookCode, IssueDate, DueDate, ReturnDate, Результат);
        Исключение
            Результат.Ошибок = Результат.Ошибок + 1;
            Результат.Сообщения.Добавить("Строка " + НомерСтроки + " (loan_id=" + LoanId + "): " + ОписаниеОшибки());
        КонецПопытки;
        
    КонецЦикла;
    
    Чтение.Закрыть();
    Возврат Результат;
    
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НайтиИлиСоздатьКнигу(BookCode, Title, Author, Year, UDK, Результат)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ Ссылка ИЗ Справочник.Книги
         | ГДЕ Код = &Код");
    Запрос.УстановитьПараметр("Код", BookCode);
    Выборка = Запрос.Выполнить().Выбрать();
    
    Если Выборка.Следующий() Тогда
        Объект = Выборка.Ссылка.ПолучитьОбъект();
        Обновлён = Ложь;
        Если Объект.Наименование <> Title Тогда Объект.Наименование = Title; Обновлён = Истина; КонецЕсли;
        Если Объект.Автор <> Author Тогда Объект.Автор = Author; Обновлён = Истина; КонецЕсли;
        Если Объект.ГодИздания <> Year Тогда Объект.ГодИздания = Year; Обновлён = Истина; КонецЕсли;
        Если Объект.УДК <> UDK Тогда Объект.УДК = UDK; Обновлён = Истина; КонецЕсли;
        Если Обновлён Тогда
            Объект.Записать();
            Результат.Обновлено = Результат.Обновлено + 1;
        Иначе
            Результат.Пропущено = Результат.Пропущено + 1;
        КонецЕсли;
        Возврат Объект.Ссылка;
    КонецЕсли;
    
    НовыйОбъект = Справочники.Книги.СоздатьЭлемент();
    НовыйОбъект.Код = BookCode;
    НовыйОбъект.Наименование = Title;
    НовыйОбъект.Автор = Author;
    НовыйОбъект.ГодИздания = Year;
    НовыйОбъект.УДК = UDK;
    НовыйОбъект.Статус = "Доступна";
    НовыйОбъект.Записать();
    Результат.Создано = Результат.Создано + 1;
    Возврат НовыйОбъект.Ссылка;
    
КонецФункции

Функция НайтиИлиСоздатьЧитателя(ReaderId, FIO, Group, Результат)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ Ссылка ИЗ Справочник.Читатели ГДЕ Код = &Код");
    Запрос.УстановитьПараметр("Код", ReaderId);
    Выборка = Запрос.Выполнить().Выбрать();
    
    Если Выборка.Следующий() Тогда
        Объект = Выборка.Ссылка.ПолучитьОбъект();
        Обновлён = Ложь;
        Если Объект.ФИО <> FIO Тогда Объект.ФИО = FIO; Объект.Наименование = FIO; Обновлён = Истина; КонецЕсли;
        Если Объект.Группа <> Group Тогда Объект.Группа = Group; Обновлён = Истина; КонецЕсли;
        Если Обновлён Тогда
            Объект.Записать();
            Результат.Обновлено = Результат.Обновлено + 1;
        Иначе
            Результат.Пропущено = Результат.Пропущено + 1;
        КонецЕсли;
        Возврат Объект.Ссылка;
    КонецЕсли;
    
    НовыйОбъект = Справочники.Читатели.СоздатьЭлемент();
    НовыйОбъект.Код = ReaderId;
    НовыйОбъект.Наименование = FIO;
    НовыйОбъект.ФИО = FIO;
    НовыйОбъект.Группа = Group;
    НовыйОбъект.ДатаРегистрации = ТекущаяДата();
    НовыйОбъект.Записать();
    Результат.Создано = Результат.Создано + 1;
    Возврат НовыйОбъект.Ссылка;
    
КонецФункции

Процедура ИмпортОднойВыдачи(LoanId, ReaderId, BookCode, IssueDate, DueDate, ReturnDate, Результат)
    
    Книга = РаботаСКнигами.ПолучитьКнигуПоКоду(BookCode);
    Если Книга = Неопределено ИЛИ Книга = Справочники.Книги.ПустаяСсылка() Тогда
        ВызватьИсключение "Неизвестная книга: " + BookCode + " (" + ОбщегоНазначения.КодОшибки("НЕИЗВЕСТНАЯ_КНИГА") + ")";
    КонецЕсли;
    
    Читатель = РаботаСЧитателями.ПолучитьЧитателяПоИД(ReaderId);
    Если Читатель = Неопределено ИЛИ Читатель = Справочники.Читатели.ПустаяСсылка() Тогда
        ВызватьИсключение "Неизвестный читатель: " + ReaderId + " (" + ОбщегоНазначения.КодОшибки("НЕИЗВЕСТНЫЙ_ЧИТАТЕЛЬ") + ")";
    КонецЕсли;
    
    // Идемпотентность: ищем существующий документ по LoanId (номер).
    Запрос = Новый Запрос(
        "ВЫБРАТЬ Ссылка ИЗ Документ.ВыдачаКниги
         |ГДЕ Номер = &Номер");
    Запрос.УстановитьПараметр("Номер", LoanId);
    Выборка = Запрос.Выполнить().Выбрать();
    
    Если Выборка.Следующий() Тогда
        Результат.Пропущено = Результат.Пропущено + 1;
        ИмеющаясяВыдача = Выборка.Ссылка;
        Если ЗначениеЗаполнено(ReturnDate) Тогда
            // Добавим возврат, если его ещё нет
            ДобавитьВозвратЕслиНужно(ИмеющаясяВыдача, ReturnDate, Результат);
        КонецЕсли;
        Возврат;
    КонецЕсли;
    
    // Создаём выдачу
    Документ = Документы.ВыдачаКниги.СоздатьДокумент();
    Документ.Номер = LoanId;
    Документ.Дата = IssueDate;
    Документ.Книга = Книга;
    Документ.Читатель = Читатель;
    Документ.ПлановаяДатаВозврата = DueDate;
    Документ.Записать(РежимЗаписиДокумента.Проведение);
    Результат.Создано = Результат.Создано + 1;
    
    Если ЗначениеЗаполнено(ReturnDate) Тогда
        ДобавитьВозвратЕслиНужно(Документ.Ссылка, ReturnDate, Результат);
    КонецЕсли;
    
КонецПроцедуры

Процедура ДобавитьВозвратЕслиНужно(СсылкаВыдачи, ДатаВозврата, Результат)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ Ссылка ИЗ Документ.ВозвратКниги
         |ГДЕ ДокументВыдачи = &Выдача");
    Запрос.УстановитьПараметр("Выдача", СсылкаВыдачи);
    Если Запрос.Выполнить().Выбрать().Следующий() Тогда
        Возврат; // уже есть
    КонецЕсли;
    
    ДокументВыдачи = СсылкаВыдачи.ПолучитьОбъект();
    Возврат_ = Документы.ВозвратКниги.СоздатьДокумент();
    Возврат_.Дата = ДатаВозврата;
    Возврат_.ДокументВыдачи = СсылкаВыдачи;
    Возврат_.Книга = ДокументВыдачи.Книга;
    Возврат_.Читатель = ДокументВыдачи.Читатель;
    Возврат_.ПлановаяДатаВозврата = ДокументВыдачи.ПлановаяДатаВозврата;
    Возврат_.ДатаВозврата = ДатаВозврата;
    Возврат_.ДнейПросрочки = ОбщегоНазначения.РассчитатьДниПросрочки(
        ДокументВыдачи.Дата, ДокументВыдачи.ПлановаяДатаВозврата, ДатаВозврата);
    Возврат_.СостояниеКниги = "Норма";
    Возврат_.Записать(РежимЗаписиДокумента.Проведение);
    
КонецПроцедуры

#КонецОбласти
