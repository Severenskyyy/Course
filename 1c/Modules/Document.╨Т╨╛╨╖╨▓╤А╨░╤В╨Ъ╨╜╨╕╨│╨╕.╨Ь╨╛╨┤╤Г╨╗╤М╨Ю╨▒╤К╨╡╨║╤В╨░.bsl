///////////////////////////////////////////////////////////////////////////////
// МОДУЛЬ ОБЪЕКТА: Документ.ВозвратКниги
// Библиотека АБИС — проведение возврата книги и списание активной выдачи
///////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    
    // BR-05: должен быть указан исходный документ выдачи
    Если НЕ ЗначениеЗаполнено(ДокументВыдачи) Тогда
        Сообщить("BR-05: не указан исходный документ выдачи");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Согласованность дат: return_date >= due_date в явных сценариях — допустимо
    // (просрочка), но return_date НЕ может быть раньше issue_date.
    ДанныеВыдачи = ДокументВыдачи.ПолучитьОбъект();
    Если ЗначениеЗаполнено(ДатаВозврата) И ДатаВозврата < ДанныеВыдачи.Дата Тогда
        Сообщить("BR-02: дата возврата раньше даты выдачи");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Копируем плановую дату и считаем просрочку
    ПлановаяДатаВозврата = ДанныеВыдачи.ПлановаяДатаВозврата;
    ДнейПросрочки = ОбщегоНазначения.РассчитатьДниПросрочки(
        ДанныеВыдачи.Дата, ПлановаяДатаВозврата, ДатаВозврата);
    
    // Списание из регистра "Выдачи"
    Движения.Выдачи.Записывать = Истина;
    Движение = Движения.Выдачи.ДобавитьРасход();
    Движение.Период = ДатаВозврата;
    Движение.Книга = Книга;
    Движение.Читатель = Читатель;
    Движение.Количество = 1;
    Движение.ДокументВыдачи = ДокументВыдачи;
    Движение.ПлановаяДатаВозврата = ПлановаяДатаВозврата;
    
    ОбщегоНазначения.ЗаписатьВЖурнал("Возврат.Проведение",
        УровеньЖурналаРегистрации.Информация,
        СтрШаблон("Возврат %1: книга %2, просрочка %3 дн.", Номер, Книга, ДнейПросрочки));
    
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
    Если НЕ ЗначениеЗаполнено(ДатаВозврата) Тогда
        ДатаВозврата = НачалоДня(ТекущаяДата());
    КонецЕсли;
    
    Если НЕ ЗначениеЗаполнено(Библиотекарь) Тогда
        Библиотекарь = ПараметрыСеанса.ТекущийПользователь;
    КонецЕсли;
    
    // Автоподтягиваем книгу/читателя из документа выдачи если пусты
    Если ЗначениеЗаполнено(ДокументВыдачи) Тогда
        Выдача = ДокументВыдачи.ПолучитьОбъект();
        Если НЕ ЗначениеЗаполнено(Книга) Тогда Книга = Выдача.Книга; КонецЕсли;
        Если НЕ ЗначениеЗаполнено(Читатель) Тогда Читатель = Выдача.Читатель; КонецЕсли;
        Если НЕ ЗначениеЗаполнено(ПлановаяДатаВозврата) Тогда
            ПлановаяДатаВозврата = Выдача.ПлановаяДатаВозврата;
        КонецЕсли;
    КонецЕсли;
    
КонецПроцедуры

#КонецОбласти
