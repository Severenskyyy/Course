#Область ПрограммныйИнтерфейс

// Создаёт новую книгу в справочнике
//
// Параметры:
//  КодКниги     - Строка - уникальный код книги (например, "BK0001")
//  Название    - Строка - название книги
//  Автор       - Строка - автор книги
//  ГодИздания  - Число  - год издания
//  УДК         - Строка - классификатор УДК
//  Описание    - Строка - описание книги (необязательно)
//  Издательство - Строка - издательство (необязательно)
//  СтраницКоличество - Число - количество страниц (необязательно)
//  ISBN        - Строка - ISBN (необязательно)
//
// Возвращаемое значение:
//  СправочникСсылка.Книги - ссылка на созданную книгу
//
Функция СоздатьКнигу(КодКниги, Название, Автор, ГодИздания, УДК, 
    Описание = "", Издательство = "", СтраницКоличество = 0, ISBN = "") Экспорт
    
    // Проверяем уникальность кода
    Если КнигаСуществует(КодКниги) Тогда
        ВызватьИсключение "Книга с кодом " + КодКниги + " уже существует";
    КонецЕсли;
    
    // Валидация данных
    Если ПустаяСтрока(СокрЛП(Название)) Тогда
        ВызватьИсключение "Название книги не может быть пустым";
    КонецЕсли;
    
    Если ПустаяСтрока(СокрЛП(Автор)) Тогда
        ВызватьИсключение "Автор книги не может быть пустым";
    КонецЕсли;
    
    Если ГодИздания < 1000 ИЛИ ГодИздания > Год(ТекущаяДата()) + 1 Тогда
        ВызватьИсключение "Некорректный год издания";
    КонецЕсли;
    
    // Создаём элемент справочника
    НоваяКнига = Справочники.Книги.СоздатьЭлемент();
    НоваяКнига.Код = КодКниги;
    НоваяКнига.Наименование = Название;
    НоваяКнига.Автор = Автор;
    НоваяКнига.ГодИздания = ГодИздания;
    НоваяКнига.УДК = УДК;
    НоваяКнига.Описание = Описание;
    НоваяКнига.Издательство = Издательство;
    НоваяКнига.КоличествоСтраниц = СтраницКоличество;
    НоваяКнига.ISBN = ISBN;
    НоваяКнига.Доступна = Истина;
    НоваяКнига.ДатаСоздания = ТекущаяДата();
    
    Попытка
        НоваяКнига.Записать();
    Исключение
        ВызватьИсключение "Ошибка создания книги: " + ОписаниеОшибки();
    КонецПопытки;
    
    // Записываем в журнал аудита
    ЗаписатьВЖурналАудита("Книги", КодКниги, "Создание", 
        "", Название, ПараметрыСеанса.ТекущийПользователь);
    
    Возврат НоваяКнига.Ссылка;
    
КонецФункции

// Проверяет существование книги по коду
//
// Параметры:
//  КодКниги - Строка - код книги
//
// Возвращаемое значение:
//  Булево - Истина, если книга существует
//
Функция КнигаСуществует(КодКниги) Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Книги.Ссылка
        |ИЗ
        |   Справочник.Книги КАК Книги
        |ГДЕ
        |   Книги.Код = &Код";
    Запрос.УстановитьПараметр("Код", КодКниги);
    
    Возврат НЕ Запрос.Выполнить().Пустой();
    
КонецФункции

// Получает книгу по коду
//
// Параметры:
//  КодКниги - Строка - код книги
//
// Возвращаемое значение:
//  СправочникСсылка.Книги - ссылка на книгу или Неопределено
//
Функция ПолучитьКнигуПоКоду(КодКниги) Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        |   Книги.Ссылка КАК Книга
        |ИЗ
        |   Справочник.Книги КАК Книги
        |ГДЕ
        |   Книги.Код = &Код";
    Запрос.УстановитьПараметр("Код", КодКниги);
    
    Результат = Запрос.Выполнить();
    Если Результат.Пустой() Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    Выборка = Результат.Выбрать();
    Выборка.Следующий();
    Возврат Выборка.Книга;
    
КонецФункции

// Проверяет доступность книги для выдачи
//
// Параметры:
//  Книга - СправочникСсылка.Книги - ссылка на книгу
//
// Возвращаемое значение:
//  Булево - Истина, если книга доступна
//
Функция КнигаДоступна(Книга) Экспорт
    
    Если НЕ ЗначениеЗаполнено(Книга) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем флаг доступности
    Если НЕ Книга.Доступна Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверяем, нет ли активной выдачи
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Выдачи.Регистратор
        |ИЗ
        |   РегистрНакопления.Выдачи КАК Выдачи
        |ГДЕ
        |   Выдачи.Книга = &Книга
        |   И Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)";
    Запрос.УстановитьПараметр("Книга", Книга);
    
    Возврат Запрос.Выполнить().Пустой();
    
КонецФункции

// Получает список всех книг с фильтрацией
//
// Параметры:
//  Фильтр - Структура - параметры фильтрации:
//      * Поиск        - Строка - поиск по названию или автору
//      * Автор        - Строка - фильтр по автору
//      * УДК          - Строка - фильтр по УДК
//      * ТолькоДоступные - Булево - только доступные книги
//
// Возвращаемое значение:
//  Массив - массив структур с данными книг
//
Функция ПолучитьСписокКниг(Фильтр = Неопределено) Экспорт
    
    Запрос = Новый Запрос;
    ТекстЗапроса = 
        "ВЫБРАТЬ
        |   Книги.Код КАК КодКниги,
        |   Книги.Наименование КАК Название,
        |   Книги.Автор,
        |   Книги.ГодИздания,
        |   Книги.УДК,
        |   Книги.Описание,
        |   Книги.Издательство,
        |   Книги.КоличествоСтраниц,
        |   Книги.ISBN,
        |   Книги.Доступна,
        |   Книги.ДатаСоздания
        |ИЗ
        |   Справочник.Книги КАК Книги
        |ГДЕ
        |   НЕ Книги.ПометкаУдаления";
    
    УсловияГДЕ = Новый Массив;
    
    Если Фильтр <> Неопределено Тогда
        
        Если Фильтр.Свойство("Поиск") И ЗначениеЗаполнено(Фильтр.Поиск) Тогда
            УсловияГДЕ.Добавить("(Книги.Наименование ПОДОБНО &Поиск ИЛИ Книги.Автор ПОДОБНО &Поиск)");
            Запрос.УстановитьПараметр("Поиск", "%" + Фильтр.Поиск + "%");
        КонецЕсли;
        
        Если Фильтр.Свойство("Автор") И ЗначениеЗаполнено(Фильтр.Автор) Тогда
            УсловияГДЕ.Добавить("Книги.Автор = &Автор");
            Запрос.УстановитьПараметр("Автор", Фильтр.Автор);
        КонецЕсли;
        
        Если Фильтр.Свойство("УДК") И ЗначениеЗаполнено(Фильтр.УДК) Тогда
            УсловияГДЕ.Добавить("Книги.УДК ПОДОБНО &УДК");
            Запрос.УстановитьПараметр("УДК", Фильтр.УДК + "%");
        КонецЕсли;
        
        Если Фильтр.Свойство("ТолькоДоступные") И Фильтр.ТолькоДоступные Тогда
            УсловияГДЕ.Добавить("Книги.Доступна = ИСТИНА");
        КонецЕсли;
        
    КонецЕсли;
    
    Если УсловияГДЕ.Количество() > 0 Тогда
        ТекстЗапроса = ТекстЗапроса + " И " + СтрСоединить(УсловияГДЕ, " И ");
    КонецЕсли;
    
    ТекстЗапроса = ТекстЗапроса + " УПОРЯДОЧИТЬ ПО Книги.Наименование";
    
    Запрос.Текст = ТекстЗапроса;
    Результат = Запрос.Выполнить().Выгрузить();
    
    СписокКниг = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        ДанныеКниги = Новый Структура;
        ДанныеКниги.Вставить("book_code", Строка.КодКниги);
        ДанныеКниги.Вставить("title", Строка.Название);
        ДанныеКниги.Вставить("author", Строка.Автор);
        ДанныеКниги.Вставить("year", Строка.ГодИздания);
        ДанныеКниги.Вставить("udk", Строка.УДК);
        ДанныеКниги.Вставить("description", Строка.Описание);
        ДанныеКниги.Вставить("publisher", Строка.Издательство);
        ДанныеКниги.Вставить("pages", Строка.КоличествоСтраниц);
        ДанныеКниги.Вставить("isbn", Строка.ISBN);
        ДанныеКниги.Вставить("is_available", Строка.Доступна);
        СписокКниг.Добавить(ДанныеКниги);
    КонецЦикла;
    
    Возврат СписокКниг;
    
КонецФункции

// Обновляет доступность книги
//
// Параметры:
//  Книга     - СправочникСсылка.Книги - ссылка на книгу
//  Доступна  - Булево - новое значение доступности
//
Процедура УстановитьДоступность(Книга, Доступна) Экспорт
    
    Если НЕ ЗначениеЗаполнено(Книга) Тогда
        Возврат;
    КонецЕсли;
    
    КнигаОбъект = Книга.ПолучитьОбъект();
    КнигаОбъект.Доступна = Доступна;
    КнигаОбъект.ДатаИзменения = ТекущаяДата();
    КнигаОбъект.Записать();
    
КонецПроцедуры

// Получает список уникальных авторов
//
// Возвращаемое значение:
//  Массив - массив строк с именами авторов
//
Функция ПолучитьСписокАвторов() Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ РАЗЛИЧНЫЕ
        |   Книги.Автор
        |ИЗ
        |   Справочник.Книги КАК Книги
        |ГДЕ
        |   НЕ Книги.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО
        |   Книги.Автор";
    
    Результат = Запрос.Выполнить().Выгрузить();
    
    Авторы = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        Авторы.Добавить(Строка.Автор);
    КонецЦикла;
    
    Возврат Авторы;
    
КонецФункции

// Получает список уникальных УДК
//
// Возвращаемое значение:
//  Массив - массив строк с кодами УДК
//
Функция ПолучитьСписокУДК() Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ РАЗЛИЧНЫЕ
        |   Книги.УДК
        |ИЗ
        |   Справочник.Книги КАК Книги
        |ГДЕ
        |   НЕ Книги.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО
        |   Книги.УДК";
    
    Результат = Запрос.Выполнить().Выгрузить();
    
    СписокУДК = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        СписокУДК.Добавить(Строка.УДК);
    КонецЦикла;
    
    Возврат СписокУДК;
    
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Записывает событие в журнал аудита
Процедура ЗаписатьВЖурналАудита(ТипСущности, ИДСущности, Действие, 
    СтароеЗначение, НовоеЗначение, Пользователь)
    
    НоваяЗапись = РегистрыСведений.ЖурналИзменений.СоздатьМенеджерЗаписи();
    НоваяЗапись.Период = ТекущаяДата();
    НоваяЗапись.ТипСущности = ТипСущности;
    НоваяЗапись.ИДСущности = ИДСущности;
    НоваяЗапись.Действие = Действие;
    НоваяЗапись.СтароеЗначение = СтароеЗначение;
    НоваяЗапись.НовоеЗначение = НовоеЗначение;
    НоваяЗапись.Пользователь = Пользователь;
    НоваяЗапись.Записать();
    
КонецПроцедуры

#КонецОбласти
