#Область СлужебныеПроцедурыИФункции

Функция СуммаМассива(Массив)
    Сумма = 0;
    Для Каждого Элемент Из Массив Цикл
        Сумма = Сумма + Элемент;
    КонецЦикла;
    Возврат Сумма;
КонецФункции

Функция ВычислитьМедиану(Массив)
    Если Массив.Количество() = 0 Тогда
        Возврат 0;
    КонецЕсли;
    
    // Сортируем массив
    СортированныйМассив = Новый Массив;
    Для Каждого Элемент Из Массив Цикл
        СортированныйМассив.Добавить(Элемент);
    КонецЦикла;
    СортированныйМассив.Сортировать();
    
    Количество = СортированныйМассив.Количество();
    Если Количество % 2 = 0 Тогда
        Индекс1 = Количество / 2 - 1;
        Индекс2 = Количество / 2;
        Возврат (СортированныйМассив[Индекс1] + СортированныйМассив[Индекс2]) / 2;
    Иначе
        Возврат СортированныйМассив[Цел(Количество / 2)];
    КонецЕсли;
КонецФункции

Процедура ЗаписатьВЖурналАудита(ТипСущности, ИДСущности, Действие, 
    СтароеЗначение, НовоеЗначение, Пользователь)
    
    НоваяЗапись = РегистрыСведений.ЖурналИзменений.СоздатьМенеджерЗаписи();
    НоваяЗапись.Период = ТекущаяДата();
    НоваяЗапись.ТипСущности = ТипСущности;
    НоваяЗапись.ИДСущности = ИДСущности;
    НоваяЗапись.Действие = Действие;
    НоваяЗапись.СтароеЗначение = СтароеЗначение;
    НоваяЗапись.НовоеЗначение = НовоеЗначение;
    НоваяЗапись.Пользователь = Пользователь;
    НоваяЗапись.Записать();
    
КонецПроцедуры

#КонецОбласти
