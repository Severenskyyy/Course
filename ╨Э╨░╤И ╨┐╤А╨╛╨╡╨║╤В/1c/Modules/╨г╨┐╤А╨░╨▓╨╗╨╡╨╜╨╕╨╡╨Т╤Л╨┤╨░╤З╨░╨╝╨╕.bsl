#Область ПрограммныйИнтерфейс

// Выдаёт книгу читателю
//
// Параметры:
//  Книга           - СправочникСсылка.Книги - ссылка на книгу
//  Читатель        - СправочникСсылка.Читатели - ссылка на читателя
//  ДатаВозврата    - Дата - планируемая дата возврата
//  Библиотекарь    - СправочникСсылка.Пользователи - кто выдаёт (необязательно)
//
// Возвращаемое значение:
//  ДокументСсылка.ВыдачаКниги - ссылка на созданный документ
//
Функция ВыдатьКнигу(Книга, Читатель, ДатаВозврата, Библиотекарь = Неопределено) Экспорт
    
    // Проверяем входные параметры
    Если НЕ ЗначениеЗаполнено(Книга) Тогда
        ВызватьИсключение "Не указана книга для выдачи";
    КонецЕсли;
    
    Если НЕ ЗначениеЗаполнено(Читатель) Тогда
        ВызватьИсключение "Не указан читатель";
    КонецЕсли;
    
    // Проверяем доступность книги
    Если НЕ РаботаСКнигами.КнигаДоступна(Книга) Тогда
        ВызватьИсключение "Книга """ + Книга.Наименование + """ недоступна для выдачи. " +
            "Возможно, она уже выдана другому читателю.";
    КонецЕсли;
    
    // Проверяем дату возврата
    Если НЕ ЗначениеЗаполнено(ДатаВозврата) Тогда
        // По умолчанию - 14 дней
        ДатаВозврата = ДобавитьМесяц(ТекущаяДата(), 0) + 14 * 24 * 60 * 60;
    ИначеЕсли ДатаВозврата < ТекущаяДата() Тогда
        ВызватьИсключение "Дата возврата не может быть в прошлом";
    КонецЕсли;
    
    // Определяем библиотекаря
    Если НЕ ЗначениеЗаполнено(Библиотекарь) Тогда
        Библиотекарь = ПараметрыСеанса.ТекущийПользователь;
    КонецЕсли;
    
    // Начинаем транзакцию
    НачатьТранзакцию();
    
    Попытка
        // Создаём документ выдачи
        ДокументВыдачи = Документы.ВыдачаКниги.СоздатьДокумент();
        ДокументВыдачи.Дата = ТекущаяДата();
        ДокументВыдачи.Книга = Книга;
        ДокументВыдачи.Читатель = Читатель;
        ДокументВыдачи.ДатаВозвратаПлан = ДатаВозврата;
        ДокументВыдачи.Библиотекарь = Библиотекарь;
        ДокументВыдачи.Комментарий = "";
        
        ДокументВыдачи.Записать(РежимЗаписиДокумента.Проведение);
        
        // Обновляем доступность книги
        РаботаСКнигами.УстановитьДоступность(Книга, Ложь);
        
        // Записываем в журнал аудита
        ЗаписатьВЖурналАудита("Выдача", ДокументВыдачи.Номер, "Выдача",
            "", "Книга: " + Книга.Код + ", Читатель: " + Читатель.Код,
            Библиотекарь);
        
        ЗафиксироватьТранзакцию();
        
        Возврат ДокументВыдачи.Ссылка;
        
    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение "Ошибка выдачи книги: " + ОписаниеОшибки();
    КонецПопытки;
    
КонецФункции

// Возвращает книгу
//
// Параметры:
//  Выдача          - ДокументСсылка.ВыдачаКниги - ссылка на документ выдачи
//  ДатаВозврата    - Дата - фактическая дата возврата (необязательно, по умолчанию - сегодня)
//  Библиотекарь    - СправочникСсылка.Пользователи - кто принял (необязательно)
//
// Возвращаемое значение:
//  ДокументСсылка.ВозвратКниги - ссылка на созданный документ
//
Функция ВернутьКнигу(Выдача, ДатаВозврата = Неопределено, Библиотекарь = Неопределено) Экспорт
    
    // Проверяем входные параметры
    Если НЕ ЗначениеЗаполнено(Выдача) Тогда
        ВызватьИсключение "Не указана выдача для возврата";
    КонецЕсли;
    
    // Проверяем, не возвращена ли уже книга
    Если КнигаУжеВозвращена(Выдача) Тогда
        ВызватьИсключение "Книга уже была возвращена";
    КонецЕсли;
    
    // Определяем дату возврата
    Если НЕ ЗначениеЗаполнено(ДатаВозврата) Тогда
        ДатаВозврата = ТекущаяДата();
    КонецЕсли;
    
    // Проверяем, что дата возврата не раньше даты выдачи
    Если ДатаВозврата < Выдача.Дата Тогда
        ВызватьИсключение "Дата возврата не может быть раньше даты выдачи";
    КонецЕсли;
    
    // Определяем библиотекаря
    Если НЕ ЗначениеЗаполнено(Библиотекарь) Тогда
        Библиотекарь = ПараметрыСеанса.ТекущийПользователь;
    КонецЕсли;
    
    // Вычисляем просрочку
    ЕстьПросрочка = ДатаВозврата > Выдача.ДатаВозвратаПлан;
    ДнейПросрочки = 0;
    Если ЕстьПросрочка Тогда
        ДнейПросрочки = Цел((ДатаВозврата - Выдача.ДатаВозвратаПлан) / (24 * 60 * 60));
    КонецЕсли;
    
    // Начинаем транзакцию
    НачатьТранзакцию();
    
    Попытка
        // Создаём документ возврата
        ДокументВозврата = Документы.ВозвратКниги.СоздатьДокумент();
        ДокументВозврата.Дата = ДатаВозврата;
        ДокументВозврата.ДокументВыдачи = Выдача;
        ДокументВозврата.Книга = Выдача.Книга;
        ДокументВозврата.Читатель = Выдача.Читатель;
        ДокументВозврата.Библиотекарь = Библиотекарь;
        ДокументВозврата.ЕстьПросрочка = ЕстьПросрочка;
        ДокументВозврата.ДнейПросрочки = ДнейПросрочки;
        
        ДокументВозврата.Записать(РежимЗаписиДокумента.Проведение);
        
        // Обновляем доступность книги
        РаботаСКнигами.УстановитьДоступность(Выдача.Книга, Истина);
        
        // Записываем в журнал аудита
        ТекстЛога = "Книга: " + Выдача.Книга.Код + ", Читатель: " + Выдача.Читатель.Код;
        Если ЕстьПросрочка Тогда
            ТекстЛога = ТекстЛога + ", Просрочка: " + ДнейПросрочки + " дн.";
        КонецЕсли;
        
        ЗаписатьВЖурналАудита("Выдача", Выдача.Номер, "Возврат",
            "", ТекстЛога, Библиотекарь);
        
        ЗафиксироватьТранзакцию();
        
        Возврат ДокументВозврата.Ссылка;
        
    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение "Ошибка возврата книги: " + ОписаниеОшибки();
    КонецПопытки;
    
КонецФункции

// Проверяет, была ли книга уже возвращена
//
// Параметры:
//  Выдача - ДокументСсылка.ВыдачаКниги - ссылка на документ выдачи
//
// Возвращаемое значение:
//  Булево - Истина, если книга уже возвращена
//
Функция КнигаУжеВозвращена(Выдача) Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   ВозвратКниги.Ссылка
        |ИЗ
        |   Документ.ВозвратКниги КАК ВозвратКниги
        |ГДЕ
        |   ВозвратКниги.ДокументВыдачи = &Выдача
        |   И ВозвратКниги.Проведен";
    Запрос.УстановитьПараметр("Выдача", Выдача);
    
    Возврат НЕ Запрос.Выполнить().Пустой();
    
КонецФункции

// Получает список активных выдач (не возвращённых)
//
// Параметры:
//  Фильтр - Структура - параметры фильтрации:
//      * Читатель          - СправочникСсылка.Читатели
//      * Книга             - СправочникСсылка.Книги
//      * ТолькоПросроченные - Булево
//      * НачалоПериода     - Дата
//      * КонецПериода      - Дата
//
// Возвращаемое значение:
//  Массив - массив структур с данными выдач
//
Функция ПолучитьАктивныеВыдачи(Фильтр = Неопределено) Экспорт
    
    Запрос = Новый Запрос;
    ТекстЗапроса = 
        "ВЫБРАТЬ
        |   Выдачи.Регистратор.Номер КАК НомерВыдачи,
        |   Выдачи.Читатель.Код КАК ИДЧитателя,
        |   Выдачи.Читатель.Наименование КАК ФИОЧитателя,
        |   Выдачи.Читатель.Группа КАК ГруппаЧитателя,
        |   Выдачи.Книга.Код КАК КодКниги,
        |   Выдачи.Книга.Наименование КАК НазваниеКниги,
        |   Выдачи.Книга.Автор КАК АвторКниги,
        |   Выдачи.ДатаВыдачи,
        |   Выдачи.ДатаВозвратаПлан КАК СрокВозврата,
        |   ВЫБОР
        |       КОГДА Выдачи.ДатаВозвратаПлан < &Сегодня
        |           ТОГДА ИСТИНА
        |       ИНАЧЕ ЛОЖЬ
        |   КОНЕЦ КАК Просрочена,
        |   ВЫБОР
        |       КОГДА Выдачи.ДатаВозвратаПлан < &Сегодня
        |           ТОГДА РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, &Сегодня, ДЕНЬ)
        |       ИНАЧЕ 0
        |   КОНЕЦ КАК ДнейПросрочки
        |ИЗ
        |   РегистрНакопления.Выдачи КАК Выдачи
        |ГДЕ
        |   Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)";
    
    Запрос.УстановитьПараметр("Сегодня", НачалоДня(ТекущаяДата()));
    
    УсловияГДЕ = Новый Массив;
    
    Если Фильтр <> Неопределено Тогда
        
        Если Фильтр.Свойство("Читатель") И ЗначениеЗаполнено(Фильтр.Читатель) Тогда
            УсловияГДЕ.Добавить("Выдачи.Читатель = &Читатель");
            Запрос.УстановитьПараметр("Читатель", Фильтр.Читатель);
        КонецЕсли;
        
        Если Фильтр.Свойство("Книга") И ЗначениеЗаполнено(Фильтр.Книга) Тогда
            УсловияГДЕ.Добавить("Выдачи.Книга = &Книга");
            Запрос.УстановитьПараметр("Книга", Фильтр.Книга);
        КонецЕсли;
        
        Если Фильтр.Свойство("ТолькоПросроченные") И Фильтр.ТолькоПросроченные Тогда
            УсловияГДЕ.Добавить("Выдачи.ДатаВозвратаПлан < &Сегодня");
        КонецЕсли;
        
        Если Фильтр.Свойство("НачалоПериода") И ЗначениеЗаполнено(Фильтр.НачалоПериода) Тогда
            УсловияГДЕ.Добавить("Выдачи.ДатаВыдачи >= &НачалоПериода");
            Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Фильтр.НачалоПериода));
        КонецЕсли;
        
        Если Фильтр.Свойство("КонецПериода") И ЗначениеЗаполнено(Фильтр.КонецПериода) Тогда
            УсловияГДЕ.Добавить("Выдачи.ДатаВыдачи <= &КонецПериода");
            Запрос.УстановитьПараметр("КонецПериода", КонецДня(Фильтр.КонецПериода));
        КонецЕсли;
        
    КонецЕсли;
    
    Если УсловияГДЕ.Количество() > 0 Тогда
        ТекстЗапроса = ТекстЗапроса + " И " + СтрСоединить(УсловияГДЕ, " И ");
    КонецЕсли;
    
    ТекстЗапроса = ТекстЗапроса + " УПОРЯДОЧИТЬ ПО ДнейПросрочки УБЫВ, Выдачи.ДатаВозвратаПлан";
    
    Запрос.Текст = ТекстЗапроса;
    Результат = Запрос.Выполнить().Выгрузить();
    
    Выдачи = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        ДанныеВыдачи = Новый Структура;
        ДанныеВыдачи.Вставить("loan_id", Строка.НомерВыдачи);
        ДанныеВыдачи.Вставить("reader_id", Строка.ИДЧитателя);
        ДанныеВыдачи.Вставить("reader_fio", Строка.ФИОЧитателя);
        ДанныеВыдачи.Вставить("reader_group", Строка.ГруппаЧитателя);
        ДанныеВыдачи.Вставить("book_code", Строка.КодКниги);
        ДанныеВыдачи.Вставить("book_title", Строка.НазваниеКниги);
        ДанныеВыдачи.Вставить("book_author", Строка.АвторКниги);
        ДанныеВыдачи.Вставить("issue_date", Строка.ДатаВыдачи);
        ДанныеВыдачи.Вставить("due_date", Строка.СрокВозврата);
        ДанныеВыдачи.Вставить("is_overdue", Строка.Просрочена);
        ДанныеВыдачи.Вставить("days_overdue", Строка.ДнейПросрочки);
        Выдачи.Добавить(ДанныеВыдачи);
    КонецЦикла;
    
    Возврат Выдачи;
    
КонецФункции

// Получает отчёт о просрочках
//
// Параметры:
//  Фильтр - Структура - параметры фильтрации:
//      * Группа        - Строка - фильтр по группе читателя
//      * Автор         - Строка - фильтр по автору книги
//      * УДК           - Строка - фильтр по УДК
//      * МинДней       - Число - минимум дней просрочки
//      * МаксДней      - Число - максимум дней просрочки
//
// Возвращаемое значение:
//  Структура:
//      * Записи                - Массив - массив структур с просрочками
//      * ВсегоПросрочек        - Число
//      * ВсегоАктивныхВыдач    - Число
//      * ПроцентПросрочек      - Число
//      * СредняяПросрочка      - Число
//      * МедианаПросрочки      - Число
//
Функция ПолучитьОтчетПросрочки(Фильтр = Неопределено) Экспорт
    
    Сегодня = НачалоДня(ТекущаяДата());
    
    Запрос = Новый Запрос;
    ТекстЗапроса = 
        "ВЫБРАТЬ
        |   Выдачи.Читатель.Код КАК reader_id,
        |   Выдачи.Читатель.Наименование КАК fio,
        |   Выдачи.Читатель.Группа КАК ""group"",
        |   Выдачи.Книга.Код КАК book_code,
        |   Выдачи.Книга.Наименование КАК title,
        |   Выдачи.Книга.Автор КАК author,
        |   Выдачи.Книга.УДК КАК udk,
        |   Выдачи.ДатаВыдачи КАК issue_date,
        |   Выдачи.ДатаВозвратаПлан КАК due_date,
        |   Выдачи.ДатаВозврата КАК return_date,
        |   ВЫБОР
        |       КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
        |           ТОГДА РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, &Сегодня, ДЕНЬ)
        |       ИНАЧЕ РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, Выдачи.ДатаВозврата, ДЕНЬ)
        |   КОНЕЦ КАК days_overdue
        |ИЗ
        |   РегистрНакопления.Выдачи КАК Выдачи
        |ГДЕ
        |   (Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозвратаПлан < &Сегодня)
        |   ИЛИ (Выдачи.ДатаВозврата <> ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозврата > Выдачи.ДатаВозвратаПлан)";
    
    Запрос.УстановитьПараметр("Сегодня", Сегодня);
    
    УсловияГДЕ = Новый Массив;
    
    Если Фильтр <> Неопределено Тогда
        
        Если Фильтр.Свойство("Группа") И ЗначениеЗаполнено(Фильтр.Группа) Тогда
            УсловияГДЕ.Добавить("Выдачи.Читатель.Группа = &Группа");
            Запрос.УстановитьПараметр("Группа", Фильтр.Группа);
        КонецЕсли;
        
        Если Фильтр.Свойство("Автор") И ЗначениеЗаполнено(Фильтр.Автор) Тогда
            УсловияГДЕ.Добавить("Выдачи.Книга.Автор = &Автор");
            Запрос.УстановитьПараметр("Автор", Фильтр.Автор);
        КонецЕсли;
        
        Если Фильтр.Свойство("УДК") И ЗначениеЗаполнено(Фильтр.УДК) Тогда
            УсловияГДЕ.Добавить("Выдачи.Книга.УДК ПОДОБНО &УДК");
            Запрос.УстановитьПараметр("УДК", Фильтр.УДК + "%");
        КонецЕсли;
        
        Если Фильтр.Свойство("МинДней") И ЗначениеЗаполнено(Фильтр.МинДней) Тогда
            УсловияГДЕ.Добавить("days_overdue >= &МинДней");
            Запрос.УстановитьПараметр("МинДней", Фильтр.МинДней);
        КонецЕсли;
        
        Если Фильтр.Свойство("МаксДней") И ЗначениеЗаполнено(Фильтр.МаксДней) Тогда
            УсловияГДЕ.Добавить("days_overdue <= &МаксДней");
            Запрос.УстановитьПараметр("МаксДней", Фильтр.МаксДней);
        КонецЕсли;
        
    КонецЕсли;
    
    Если УсловияГДЕ.Количество() > 0 Тогда
        ТекстЗапроса = ТекстЗапроса + " И " + СтрСоединить(УсловияГДЕ, " И ");
    КонецЕсли;
    
    ТекстЗапроса = ТекстЗапроса + " УПОРЯДОЧИТЬ ПО days_overdue УБЫВ";
    
    Запрос.Текст = ТекстЗапроса;
    Результат = Запрос.Выполнить().Выгрузить();
    
    // Собираем данные
    Записи = Новый Массив;
    ДниПросрочки = Новый Массив;
    ТекущиеПросрочки = 0;
    
    Для Каждого Строка Из Результат Цикл
        ДанныеЗаписи = Новый Структура;
        ДанныеЗаписи.Вставить("reader_id", Строка.reader_id);
        ДанныеЗаписи.Вставить("fio", Строка.fio);
        ДанныеЗаписи.Вставить("group", Строка.group);
        ДанныеЗаписи.Вставить("book_code", Строка.book_code);
        ДанныеЗаписи.Вставить("title", Строка.title);
        ДанныеЗаписи.Вставить("author", Строка.author);
        ДанныеЗаписи.Вставить("issue_date", Строка.issue_date);
        ДанныеЗаписи.Вставить("due_date", Строка.due_date);
        ДанныеЗаписи.Вставить("return_date", ?(Строка.return_date = Дата(1,1,1), Неопределено, Строка.return_date));
        ДанныеЗаписи.Вставить("days_overdue", Строка.days_overdue);
        Записи.Добавить(ДанныеЗаписи);
        
        Если Строка.days_overdue > 0 Тогда
            ДниПросрочки.Добавить(Строка.days_overdue);
        КонецЕсли;
        
        Если Строка.return_date = Дата(1,1,1) Тогда
            ТекущиеПросрочки = ТекущиеПросрочки + 1;
        КонецЕсли;
    КонецЦикла;
    
    // Получаем общее количество активных выдач
    ЗапросАктивных = Новый Запрос;
    ЗапросАктивных.Текст = 
        "ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Количество
        |ИЗ РегистрНакопления.Выдачи
        |ГДЕ ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)";
    РезультатАктивных = ЗапросАктивных.Выполнить().Выбрать();
    РезультатАктивных.Следующий();
    ВсегоАктивных = РезультатАктивных.Количество;
    
    // Вычисляем статистику
    ПроцентПросрочек = ?(ВсегоАктивных > 0, ТекущиеПросрочки / ВсегоАктивных * 100, 0);
    СредняяПросрочка = ?(ДниПросрочки.Количество() > 0, 
        СуммаМассива(ДниПросрочки) / ДниПросрочки.Количество(), 0);
    МедианаПросрочки = ВычислитьМедиану(ДниПросрочки);
    
    Отчет = Новый Структура;
    Отчет.Вставить("items", Записи);
    Отчет.Вставить("total_overdue", ТекущиеПросрочки);
    Отчет.Вставить("total_active_loans", ВсегоАктивных);
    Отчет.Вставить("overdue_percentage", Окр(ПроцентПросрочек, 2));
    Отчет.Вставить("average_overdue_days", Окр(СредняяПросрочка, 2));
    Отчет.Вставить("median_overdue_days", МедианаПросрочки);
    Отчет.Вставить("generated_at", ТекущаяДата());
    
    Возврат Отчет;
    
КонецФункции

// Получает KPI показатели библиотеки
//
// Возвращаемое значение:
//  Структура - KPI показатели
//
Функция ПолучитьKPI() Экспорт
    
    Сегодня = НачалоДня(ТекущаяДата());
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        |   (ВЫБРАТЬ КОЛИЧЕСТВО(*) ИЗ Справочник.Книги ГДЕ НЕ ПометкаУдаления) КАК ВсегоКниг,
        |   (ВЫБРАТЬ КОЛИЧЕСТВО(*) ИЗ Справочник.Читатели ГДЕ НЕ ПометкаУдаления) КАК ВсегоЧитателей,
        |   (ВЫБРАТЬ КОЛИЧЕСТВО(*) ИЗ РегистрНакопления.Выдачи ГДЕ ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)) КАК АктивныхВыдач,
        |   (ВЫБРАТЬ КОЛИЧЕСТВО(*) ИЗ РегистрНакопления.Выдачи ГДЕ ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1) И ДатаВозвратаПлан < &Сегодня) КАК ПросроченныхВыдач,
        |   (ВЫБРАТЬ КОЛИЧЕСТВО(*) ИЗ Справочник.Книги ГДЕ НЕ ПометкаУдаления И НЕ Доступна) КАК КнигВОбращении";
    
    Запрос.УстановитьПараметр("Сегодня", Сегодня);
    
    Результат = Запрос.Выполнить().Выбрать();
    Результат.Следующий();
    
    ПроцентПросрочек = ?(Результат.АктивныхВыдач > 0, 
        Результат.ПросроченныхВыдач / Результат.АктивныхВыдач * 100, 0);
    
    КоэффициентОборачиваемости = ?(Результат.ВсегоКниг > 0,
        Результат.КнигВОбращении / Результат.ВсегоКниг * 100, 0);
    
    ЦелевойПорог = 15.0; // Согласно ТЗ: доля просроченных выдач ≤ 15%
    
    KPI = Новый Структура;
    KPI.Вставить("total_books", Результат.ВсегоКниг);
    KPI.Вставить("total_readers", Результат.ВсегоЧитателей);
    KPI.Вставить("active_loans", Результат.АктивныхВыдач);
    KPI.Вставить("overdue_loans", Результат.ПросроченныхВыдач);
    KPI.Вставить("overdue_percentage", Окр(ПроцентПросрочек, 2));
    KPI.Вставить("target_threshold", ЦелевойПорог);
    KPI.Вставить("is_within_target", ПроцентПросрочек <= ЦелевойПорог);
    KPI.Вставить("books_in_circulation", Результат.КнигВОбращении);
    KPI.Вставить("circulation_rate", Окр(КоэффициентОборачиваемости, 2));
    
    Возврат KPI;
    
КонецФункции

// Получает ТОП читателей по просрочкам
//
// Параметры:
//  Количество - Число - количество записей в ТОП (по умолчанию 5)
//
// Возвращаемое значение:
//  Массив - массив структур с данными читателей
//
Функция ПолучитьТОПЧитателейПоПросрочкам(Количество = 5) Экспорт
    
    Сегодня = НачалоДня(ТекущаяДата());
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ " + Формат(Количество, "ЧГ=0") + "
        |   Выдачи.Читатель.Код КАК reader_id,
        |   Выдачи.Читатель.Наименование КАК fio,
        |   Выдачи.Читатель.Группа КАК ""group"",
        |   КОЛИЧЕСТВО(*) КАК overdue_count,
        |   СУММА(
        |       ВЫБОР
        |           КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
        |               ТОГДА РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, &Сегодня, ДЕНЬ)
        |           ИНАЧЕ РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, Выдачи.ДатаВозврата, ДЕНЬ)
        |       КОНЕЦ
        |   ) КАК total_overdue_days
        |ИЗ
        |   РегистрНакопления.Выдачи КАК Выдачи
        |ГДЕ
        |   (Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозвратаПлан < &Сегодня)
        |   ИЛИ (Выдачи.ДатаВозврата <> ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозврата > Выдачи.ДатаВозвратаПлан)
        |СГРУППИРОВАТЬ ПО
        |   Выдачи.Читатель.Код,
        |   Выдачи.Читатель.Наименование,
        |   Выдачи.Читатель.Группа
        |УПОРЯДОЧИТЬ ПО
        |   overdue_count УБЫВ,
        |   total_overdue_days УБЫВ";
    
    Запрос.УстановитьПараметр("Сегодня", Сегодня);
    
    Результат = Запрос.Выполнить().Выгрузить();
    
    ТОП = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        Данные = Новый Структура;
        Данные.Вставить("reader_id", Строка.reader_id);
        Данные.Вставить("fio", Строка.fio);
        Данные.Вставить("group", Строка.group);
        Данные.Вставить("overdue_count", Строка.overdue_count);
        Данные.Вставить("total_overdue_days", Строка.total_overdue_days);
        ТОП.Добавить(Данные);
    КонецЦикла;
    
    Возврат ТОП;
    
КонецФункции

