#Область ПрограммныйИнтерфейс

// Создаёт нового читателя в справочнике
//
// Параметры:
//  ИДЧитателя  - Строка - уникальный идентификатор (например, "RD0001")
//  ФИО         - Строка - полное имя читателя
//  Группа      - Строка - группа/класс читателя
//  Email       - Строка - электронная почта (необязательно)
//  Телефон     - Строка - номер телефона (необязательно)
//
// Возвращаемое значение:
//  СправочникСсылка.Читатели - ссылка на созданного читателя
//
Функция СоздатьЧитателя(ИДЧитателя, ФИО, Группа, Email = "", Телефон = "") Экспорт
    
    // Проверяем уникальность ID
    Если ЧитательСуществует(ИДЧитателя) Тогда
        ВызватьИсключение "Читатель с ID " + ИДЧитателя + " уже существует";
    КонецЕсли;
    
    // Валидация ФИО
    Если ПустаяСтрока(СокрЛП(ФИО)) ИЛИ СтрДлина(СокрЛП(ФИО)) < 2 Тогда
        ВызватьИсключение "ФИО читателя должно содержать минимум 2 символа";
    КонецЕсли;
    
    // Валидация группы
    Если ПустаяСтрока(СокрЛП(Группа)) Тогда
        ВызватьИсключение "Группа читателя не может быть пустой";
    КонецЕсли;
    
    // Валидация email (базовая)
    Если ЗначениеЗаполнено(Email) И НЕ СтрНайти(Email, "@") > 0 Тогда
        ВызватьИсключение "Некорректный формат email";
    КонецЕсли;
    
    // Создаём элемент справочника
    НовыйЧитатель = Справочники.Читатели.СоздатьЭлемент();
    НовыйЧитатель.Код = ИДЧитателя;
    НовыйЧитатель.Наименование = ФИО;
    НовыйЧитатель.Группа = Группа;
    НовыйЧитатель.Email = Email;
    НовыйЧитатель.Телефон = Телефон;
    НовыйЧитатель.ДатаРегистрации = ТекущаяДата();
    НовыйЧитатель.Активен = Истина;
    
    Попытка
        НовыйЧитатель.Записать();
    Исключение
        ВызватьИсключение "Ошибка создания читателя: " + ОписаниеОшибки();
    КонецПопытки;
    
    // Записываем в журнал аудита
    ЗаписатьВЖурналАудита("Читатели", ИДЧитателя, "Создание",
        "", ФИО, ПараметрыСеанса.ТекущийПользователь);
    
    Возврат НовыйЧитатель.Ссылка;
    
КонецФункции

// Проверяет существование читателя по ID
//
// Параметры:
//  ИДЧитателя - Строка - идентификатор читателя
//
// Возвращаемое значение:
//  Булево - Истина, если читатель существует
//
Функция ЧитательСуществует(ИДЧитателя) Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Читатели.Ссылка
        |ИЗ
        |   Справочник.Читатели КАК Читатели
        |ГДЕ
        |   Читатели.Код = &Код";
    Запрос.УстановитьПараметр("Код", ИДЧитателя);
    
    Возврат НЕ Запрос.Выполнить().Пустой();
    
КонецФункции

// Получает читателя по ID
//
// Параметры:
//  ИДЧитателя - Строка - идентификатор читателя
//
// Возвращаемое значение:
//  СправочникСсылка.Читатели - ссылка на читателя или Неопределено
//
Функция ПолучитьЧитателяПоИД(ИДЧитателя) Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        |   Читатели.Ссылка КАК Читатель
        |ИЗ
        |   Справочник.Читатели КАК Читатели
        |ГДЕ
        |   Читатели.Код = &Код";
    Запрос.УстановитьПараметр("Код", ИДЧитателя);
    
    Результат = Запрос.Выполнить();
    Если Результат.Пустой() Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    Выборка = Результат.Выбрать();
    Выборка.Следующий();
    Возврат Выборка.Читатель;
    
КонецФункции

// Получает список активных выдач читателя
//
// Параметры:
//  Читатель - СправочникСсылка.Читатели - ссылка на читателя
//
// Возвращаемое значение:
//  Массив - массив структур с данными выдач
//
Функция ПолучитьАктивныеВыдачиЧитателя(Читатель) Экспорт
    
    Если НЕ ЗначениеЗаполнено(Читатель) Тогда
        Возврат Новый Массив;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        |   Выдачи.Регистратор.Номер КАК НомерВыдачи,
        |   Выдачи.Книга.Код КАК КодКниги,
        |   Выдачи.Книга.Наименование КАК НазваниеКниги,
        |   Выдачи.Книга.Автор КАК АвторКниги,
        |   Выдачи.ДатаВыдачи,
        |   Выдачи.ДатаВозвратаПлан КАК СрокВозврата,
        |   ВЫБОР
        |       КОГДА Выдачи.ДатаВозвратаПлан < &Сегодня
        |           ТОГДА РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, &Сегодня, ДЕНЬ)
        |       ИНАЧЕ 0
        |   КОНЕЦ КАК ДнейПросрочки
        |ИЗ
        |   РегистрНакопления.Выдачи КАК Выдачи
        |ГДЕ
        |   Выдачи.Читатель = &Читатель
        |   И Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
        |УПОРЯДОЧИТЬ ПО
        |   Выдачи.ДатаВозвратаПлан";
    
    Запрос.УстановитьПараметр("Читатель", Читатель);
    Запрос.УстановитьПараметр("Сегодня", НачалоДня(ТекущаяДата()));
    
    Результат = Запрос.Выполнить().Выгрузить();
    
    Выдачи = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        ДанныеВыдачи = Новый Структура;
        ДанныеВыдачи.Вставить("loan_id", Строка.НомерВыдачи);
        ДанныеВыдачи.Вставить("book_code", Строка.КодКниги);
        ДанныеВыдачи.Вставить("book_title", Строка.НазваниеКниги);
        ДанныеВыдачи.Вставить("book_author", Строка.АвторКниги);
        ДанныеВыдачи.Вставить("issue_date", Строка.ДатаВыдачи);
        ДанныеВыдачи.Вставить("due_date", Строка.СрокВозврата);
        ДанныеВыдачи.Вставить("days_overdue", Строка.ДнейПросрочки);
        ДанныеВыдачи.Вставить("is_overdue", Строка.ДнейПросрочки > 0);
        Выдачи.Добавить(ДанныеВыдачи);
    КонецЦикла;
    
    Возврат Выдачи;
    
КонецФункции

// Получает историю выдач читателя
//
// Параметры:
//  Читатель - СправочникСсылка.Читатели - ссылка на читателя
//  Период   - Структура - необязательно:
//      * НачалоПериода - Дата
//      * КонецПериода  - Дата
//
// Возвращаемое значение:
//  Массив - массив структур с историей выдач
//
Функция ПолучитьИсториюВыдачЧитателя(Читатель, Период = Неопределено) Экспорт
    
    Если НЕ ЗначениеЗаполнено(Читатель) Тогда
        Возврат Новый Массив;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        |   Выдачи.Регистратор.Номер КАК НомерВыдачи,
        |   Выдачи.Книга.Код КАК КодКниги,
        |   Выдачи.Книга.Наименование КАК НазваниеКниги,
        |   Выдачи.Книга.Автор КАК АвторКниги,
        |   Выдачи.ДатаВыдачи,
        |   Выдачи.ДатаВозвратаПлан КАК СрокВозврата,
        |   Выдачи.ДатаВозврата,
        |   ВЫБОР
        |       КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
        |           ТОГДА ""Активна""
        |       КОГДА Выдачи.ДатаВозврата > Выдачи.ДатаВозвратаПлан
        |           ТОГДА ""Возвращена с просрочкой""
        |       ИНАЧЕ ""Возвращена""
        |   КОНЕЦ КАК Статус
        |ИЗ
        |   РегистрНакопления.Выдачи КАК Выдачи
        |ГДЕ
        |   Выдачи.Читатель = &Читатель";
    
    Если Период <> Неопределено Тогда
        Если Период.Свойство("НачалоПериода") И ЗначениеЗаполнено(Период.НачалоПериода) Тогда
            Запрос.Текст = Запрос.Текст + " И Выдачи.ДатаВыдачи >= &НачалоПериода";
            Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Период.НачалоПериода));
        КонецЕсли;
        Если Период.Свойство("КонецПериода") И ЗначениеЗаполнено(Период.КонецПериода) Тогда
            Запрос.Текст = Запрос.Текст + " И Выдачи.ДатаВыдачи <= &КонецПериода";
            Запрос.УстановитьПараметр("КонецПериода", КонецДня(Период.КонецПериода));
        КонецЕсли;
    КонецЕсли;
    
    Запрос.Текст = Запрос.Текст + " УПОРЯДОЧИТЬ ПО Выдачи.ДатаВыдачи УБЫВ";
    Запрос.УстановитьПараметр("Читатель", Читатель);
    
    Результат = Запрос.Выполнить().Выгрузить();
    
    История = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        ДанныеВыдачи = Новый Структура;
        ДанныеВыдачи.Вставить("loan_id", Строка.НомерВыдачи);
        ДанныеВыдачи.Вставить("book_code", Строка.КодКниги);
        ДанныеВыдачи.Вставить("book_title", Строка.НазваниеКниги);
        ДанныеВыдачи.Вставить("book_author", Строка.АвторКниги);
        ДанныеВыдачи.Вставить("issue_date", Строка.ДатаВыдачи);
        ДанныеВыдачи.Вставить("due_date", Строка.СрокВозврата);
        ДанныеВыдачи.Вставить("return_date", ?(Строка.ДатаВозврата = Дата(1,1,1), Неопределено, Строка.ДатаВозврата));
        ДанныеВыдачи.Вставить("status", Строка.Статус);
        История.Добавить(ДанныеВыдачи);
    КонецЦикла;
    
    Возврат История;
    
КонецФункции

// Получает список читателей с фильтрацией
//
// Параметры:
//  Фильтр - Структура - параметры фильтрации:
//      * Поиск - Строка - поиск по ФИО
//      * Группа - Строка - фильтр по группе
//      * ТолькоАктивные - Булево - только активные читатели
//
// Возвращаемое значение:
//  Массив - массив структур с данными читателей
//
Функция ПолучитьСписокЧитателей(Фильтр = Неопределено) Экспорт
    
    Запрос = Новый Запрос;
    ТекстЗапроса = 
        "ВЫБРАТЬ
        |   Читатели.Код КАК ИДЧитателя,
        |   Читатели.Наименование КАК ФИО,
        |   Читатели.Группа,
        |   Читатели.Email,
        |   Читатели.Телефон,
        |   Читатели.ДатаРегистрации,
        |   Читатели.Активен
        |ИЗ
        |   Справочник.Читатели КАК Читатели
        |ГДЕ
        |   НЕ Читатели.ПометкаУдаления";
    
    УсловияГДЕ = Новый Массив;
    
    Если Фильтр <> Неопределено Тогда
        
        Если Фильтр.Свойство("Поиск") И ЗначениеЗаполнено(Фильтр.Поиск) Тогда
            УсловияГДЕ.Добавить("Читатели.Наименование ПОДОБНО &Поиск");
            Запрос.УстановитьПараметр("Поиск", "%" + Фильтр.Поиск + "%");
        КонецЕсли;
        
        Если Фильтр.Свойство("Группа") И ЗначениеЗаполнено(Фильтр.Группа) Тогда
            УсловияГДЕ.Добавить("Читатели.Группа = &Группа");
            Запрос.УстановитьПараметр("Группа", Фильтр.Группа);
        КонецЕсли;
        
        Если Фильтр.Свойство("ТолькоАктивные") И Фильтр.ТолькоАктивные Тогда
            УсловияГДЕ.Добавить("Читатели.Активен = ИСТИНА");
        КонецЕсли;
        
    КонецЕсли;
    
    Если УсловияГДЕ.Количество() > 0 Тогда
        ТекстЗапроса = ТекстЗапроса + " И " + СтрСоединить(УсловияГДЕ, " И ");
    КонецЕсли;
    
    ТекстЗапроса = ТекстЗапроса + " УПОРЯДОЧИТЬ ПО Читатели.Наименование";
    
    Запрос.Текст = ТекстЗапроса;
    Результат = Запрос.Выполнить().Выгрузить();
    
    СписокЧитателей = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        ДанныеЧитателя = Новый Структура;
        ДанныеЧитателя.Вставить("reader_id", Строка.ИДЧитателя);
        ДанныеЧитателя.Вставить("fio", Строка.ФИО);
        ДанныеЧитателя.Вставить("group", Строка.Группа);
        ДанныеЧитателя.Вставить("email", Строка.Email);
        ДанныеЧитателя.Вставить("phone", Строка.Телефон);
        СписокЧитателей.Добавить(ДанныеЧитателя);
    КонецЦикла;
    
    Возврат СписокЧитателей;
    
КонецФункции

// Получает список уникальных групп
//
// Возвращаемое значение:
//  Массив - массив строк с названиями групп
//
Функция ПолучитьСписокГрупп() Экспорт
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ РАЗЛИЧНЫЕ
        |   Читатели.Группа
        |ИЗ
        |   Справочник.Читатели КАК Читатели
        |ГДЕ
        |   НЕ Читатели.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО
        |   Читатели.Группа";
    
    Результат = Запрос.Выполнить().Выгрузить();
    
    Группы = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        Группы.Добавить(Строка.Группа);
    КонецЦикла;
    
    Возврат Группы;
    
КонецФункции

// Получает статистику читателя
//
// Параметры:
//  Читатель - СправочникСсылка.Читатели - ссылка на читателя
//
// Возвращаемое значение:
//  Структура - статистика читателя:
//      * ВсегоВыдач         - Число
//      * АктивныхВыдач      - Число
//      * ПросроченныхВыдач  - Число
//      * ВсегоПросрочек     - Число (за всё время)
//      * ОбщееВремяПросрочки - Число (дни)
//
Функция ПолучитьСтатистикуЧитателя(Читатель) Экспорт
    
    Если НЕ ЗначениеЗаполнено(Читатель) Тогда
        Возврат Новый Структура("ВсегоВыдач, АктивныхВыдач, ПросроченныхВыдач, ВсегоПросрочек, ОбщееВремяПросрочки",
            0, 0, 0, 0, 0);
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ
        |   КОЛИЧЕСТВО(*) КАК ВсегоВыдач,
        |   СУММА(ВЫБОР
        |       КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
        |           ТОГДА 1
        |       ИНАЧЕ 0
        |   КОНЕЦ) КАК АктивныхВыдач,
        |   СУММА(ВЫБОР
        |       КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
        |           И Выдачи.ДатаВозвратаПлан < &Сегодня
        |           ТОГДА 1
        |       ИНАЧЕ 0
        |   КОНЕЦ) КАК ПросроченныхВыдач,
        |   СУММА(ВЫБОР
        |       КОГДА Выдачи.ДатаВозврата > Выдачи.ДатаВозвратаПлан
        |           ИЛИ (Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозвратаПлан < &Сегодня)
        |           ТОГДА 1
        |       ИНАЧЕ 0
        |   КОНЕЦ) КАК ВсегоПросрочек,
        |   СУММА(ВЫБОР
        |       КОГДА Выдачи.ДатаВозврата > Выдачи.ДатаВозвратаПлан
        |           ТОГДА РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, Выдачи.ДатаВозврата, ДЕНЬ)
        |       КОГДА Выдачи.ДатаВозврата = ДАТАВРЕМЯ(1, 1, 1) И Выдачи.ДатаВозвратаПлан < &Сегодня
        |           ТОГДА РАЗНОСТЬДАТ(Выдачи.ДатаВозвратаПлан, &Сегодня, ДЕНЬ)
        |       ИНАЧЕ 0
        |   КОНЕЦ) КАК ОбщееВремяПросрочки
        |ИЗ
        |   РегистрНакопления.Выдачи КАК Выдачи
        |ГДЕ
        |   Выдачи.Читатель = &Читатель";
    
    Запрос.УстановитьПараметр("Читатель", Читатель);
    Запрос.УстановитьПараметр("Сегодня", НачалоДня(ТекущаяДата()));
    
    Результат = Запрос.Выполнить().Выбрать();
    
    Если Результат.Следующий() Тогда
        Возврат Новый Структура("ВсегоВыдач, АктивныхВыдач, ПросроченныхВыдач, ВсегоПросрочек, ОбщееВремяПросрочки",
            Результат.ВсегоВыдач,
            Результат.АктивныхВыдач,
