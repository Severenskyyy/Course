#Область ИмпортДанных

// Импортирует книги из CSV файла
// Импорт идемпотентный - повторная загрузка не создаёт дублей
//
// Параметры:
//  ПутьКФайлу - Строка - путь к CSV файлу
//
// Возвращаемое значение:
//  Структура:
//      * Успешно       - Булево
//      * ВсегоЗаписей  - Число
//      * Импортировано - Число
//      * Пропущено     - Число
//      * Ошибки        - Массив строк с описанием ошибок
//
Функция ИмпортКнигИзCSV(ПутьКФайлу) Экспорт
    
    Результат = Новый Структура;
    Результат.Вставить("success", Ложь);
    Результат.Вставить("total_records", 0);
    Результат.Вставить("imported", 0);
    Результат.Вставить("skipped", 0);
    Результат.Вставить("errors", Новый Массив);
    
    Попытка
        ТекстCSV = Новый ТекстовыйДокумент;
        ТекстCSV.Прочитать(ПутьКФайлу, КодировкаТекста.UTF8);
        
        ПерваяСтрока = Истина;
        НомерСтроки = 0;
        
        Для НомерСтрокиТекста = 1 По ТекстCSV.КоличествоСтрок() Цикл
            Строка = ТекстCSV.ПолучитьСтроку(НомерСтрокиТекста);
            
            Если ПустаяСтрока(СокрЛП(Строка)) Тогда
                Продолжить;
            КонецЕсли;
            
            // Пропускаем заголовок
            Если ПерваяСтрока Тогда
                ПерваяСтрока = Ложь;
                Продолжить;
            КонецЕсли;
            
            НомерСтроки = НомерСтроки + 1;
            Результат.total_records = Результат.total_records + 1;
            
            Попытка
                Поля = РазобратьСтрокуCSV(Строка);
                
                // Ожидаемый формат: book_code;title;author;year;udk;description;publisher;pages;isbn
                Если Поля.Количество() < 5 Тогда
                    Результат.errors.Добавить("Строка " + НомерСтроки + ": недостаточно полей");
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                КодКниги = СокрЛП(Поля[0]);
                
                // Проверяем, существует ли книга (идемпотентность)
                Если РаботаСКнигами.КнигаСуществует(КодКниги) Тогда
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                // Создаём книгу
                РаботаСКнигами.СоздатьКнигу(
                    КодКниги,
                    СокрЛП(Поля[1]),                          // Название
                    СокрЛП(Поля[2]),                          // Автор
                    Число(СокрЛП(Поля[3])),                   // Год
                    СокрЛП(Поля[4]),                          // УДК
                    ?(Поля.Количество() > 5, СокрЛП(Поля[5]), ""),  // Описание
                    ?(Поля.Количество() > 6, СокрЛП(Поля[6]), ""),  // Издательство
                    ?(Поля.Количество() > 7, Число(СокрЛП(Поля[7])), 0),  // Страницы
                    ?(Поля.Количество() > 8, СокрЛП(Поля[8]), "")   // ISBN
                );
                
                Результат.imported = Результат.imported + 1;
                
            Исключение
                Результат.errors.Добавить("Строка " + НомерСтроки + ": " + ОписаниеОшибки());
                Результат.skipped = Результат.skipped + 1;
            КонецПопытки;
            
        КонецЦикла;
        
        Результат.success = Истина;
        
    Исключение
        Результат.errors.Добавить("Ошибка чтения файла: " + ОписаниеОшибки());
    КонецПопытки;
    
    Возврат Результат;
    
КонецФункции

// Импортирует читателей из CSV файла
//
// Параметры:
//  ПутьКФайлу - Строка - путь к CSV файлу
//
// Возвращаемое значение:
//  Структура - результат импорта (аналогично ИмпортКнигИзCSV)
//
Функция ИмпортЧитателейИзCSV(ПутьКФайлу) Экспорт
    
    Результат = Новый Структура;
    Результат.Вставить("success", Ложь);
    Результат.Вставить("total_records", 0);
    Результат.Вставить("imported", 0);
    Результат.Вставить("skipped", 0);
    Результат.Вставить("errors", Новый Массив);
    
    Попытка
        ТекстCSV = Новый ТекстовыйДокумент;
        ТекстCSV.Прочитать(ПутьКФайлу, КодировкаТекста.UTF8);
        
        ПерваяСтрока = Истина;
        НомерСтроки = 0;
        
        Для НомерСтрокиТекста = 1 По ТекстCSV.КоличествоСтрок() Цикл
            Строка = ТекстCSV.ПолучитьСтроку(НомерСтрокиТекста);
            
            Если ПустаяСтрока(СокрЛП(Строка)) Тогда
                Продолжить;
            КонецЕсли;
            
            Если ПерваяСтрока Тогда
                ПерваяСтрока = Ложь;
                Продолжить;
            КонецЕсли;
            
            НомерСтроки = НомерСтроки + 1;
            Результат.total_records = Результат.total_records + 1;
            
            Попытка
                Поля = РазобратьСтрокуCSV(Строка);
                
                // Ожидаемый формат: reader_id;fio;group;email;phone
                Если Поля.Количество() < 3 Тогда
                    Результат.errors.Добавить("Строка " + НомерСтроки + ": недостаточно полей");
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                ИДЧитателя = СокрЛП(Поля[0]);
                
                // Проверяем существование (идемпотентность)
                Если РаботаСЧитателями.ЧитательСуществует(ИДЧитателя) Тогда
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                РаботаСЧитателями.СоздатьЧитателя(
                    ИДЧитателя,
                    СокрЛП(Поля[1]),                          // ФИО
                    СокрЛП(Поля[2]),                          // Группа
                    ?(Поля.Количество() > 3, СокрЛП(Поля[3]), ""),  // Email
                    ?(Поля.Количество() > 4, СокрЛП(Поля[4]), "")   // Телефон
                );
                
                Результат.imported = Результат.imported + 1;
                
            Исключение
                Результат.errors.Добавить("Строка " + НомерСтроки + ": " + ОписаниеОшибки());
                Результат.skipped = Результат.skipped + 1;
            КонецПопытки;
            
        КонецЦикла;
        
        Результат.success = Истина;
        
    Исключение
        Результат.errors.Добавить("Ошибка чтения файла: " + ОписаниеОшибки());
    КонецПопытки;
    
    Возврат Результат;
    
КонецФункции

// Импортирует выдачи из CSV файла
//
// Параметры:
//  ПутьКФайлу - Строка - путь к CSV файлу
//
// Возвращаемое значение:
//  Структура - результат импорта
//
Функция ИмпортВыдачИзCSV(ПутьКФайлу) Экспорт
    
    Результат = Новый Структура;
    Результат.Вставить("success", Ложь);
    Результат.Вставить("total_records", 0);
    Результат.Вставить("imported", 0);
    Результат.Вставить("skipped", 0);
    Результат.Вставить("errors", Новый Массив);
    
    Попытка
        ТекстCSV = Новый ТекстовыйДокумент;
        ТекстCSV.Прочитать(ПутьКФайлу, КодировкаТекста.UTF8);
        
        ПерваяСтрока = Истина;
        НомерСтроки = 0;
        
        Для НомерСтрокиТекста = 1 По ТекстCSV.КоличествоСтрок() Цикл
            Строка = ТекстCSV.ПолучитьСтроку(НомерСтрокиТекста);
            
            Если ПустаяСтрока(СокрЛП(Строка)) Тогда
                Продолжить;
            КонецЕсли;
            
            Если ПерваяСтрока Тогда
                ПерваяСтрока = Ложь;
                Продолжить;
            КонецЕсли;
            
            НомерСтроки = НомерСтроки + 1;
            Результат.total_records = Результат.total_records + 1;
            
            Попытка
                Поля = РазобратьСтрокуCSV(Строка);
                
                // Ожидаемый формат: loan_id;reader_id;book_code;issue_date;due_date;return_date
                Если Поля.Количество() < 5 Тогда
                    Результат.errors.Добавить("Строка " + НомерСтроки + ": недостаточно полей");
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                // Проверяем существование выдачи по ID
                НомерВыдачи = СокрЛП(Поля[0]);
                Если ВыдачаСуществует(НомерВыдачи) Тогда
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                ИДЧитателя = СокрЛП(Поля[1]);
                КодКниги = СокрЛП(Поля[2]);
                
                // Получаем ссылки
                Читатель = РаботаСЧитателями.ПолучитьЧитателяПоИД(ИДЧитателя);
                Книга = РаботаСКнигами.ПолучитьКнигуПоКоду(КодКниги);
                
                Если НЕ ЗначениеЗаполнено(Читатель) Тогда
                    Результат.errors.Добавить("Строка " + НомерСтроки + ": читатель " + ИДЧитателя + " не найден");
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                Если НЕ ЗначениеЗаполнено(Книга) Тогда
                    Результат.errors.Добавить("Строка " + НомерСтроки + ": книга " + КодКниги + " не найдена");
                    Результат.skipped = Результат.skipped + 1;
                    Продолжить;
                КонецЕсли;
                
                ДатаВыдачи = ПрочитатьДатуISO(СокрЛП(Поля[3]));
                ДатаВозвратаПлан = ПрочитатьДатуISO(СокрЛП(Поля[4]));
                ДатаВозврата = ?(Поля.Количество() > 5 И ЗначениеЗаполнено(СокрЛП(Поля[5])), 
                    ПрочитатьДатуISO(СокрЛП(Поля[5])), Дата(1,1,1));
                
                // Создаём выдачу напрямую через документ
                СоздатьВыдачуИзИмпорта(НомерВыдачи, Книга, Читатель, ДатаВыдачи, ДатаВозвратаПлан, ДатаВозврата);
                
                Результат.imported = Результат.imported + 1;
                
            Исключение
                Результат.errors.Добавить("Строка " + НомерСтроки + ": " + ОписаниеОшибки());
                Результат.skipped = Результат.skipped + 1;
            КонецПопытки;
            
        КонецЦикла;
        
        Результат.success = Истина;
        
    Исключение
        Результат.errors.Добавить("Ошибка чтения файла: " + ОписаниеОшибки());
    КонецПопытки;
    
    Возврат Результат;
    
КонецФункции

#КонецОбласти

#Область ЭкспортДанных

// Экспортирует отчёт о просрочках в CSV
//
// Параметры:
//  ПутьКФайлу  - Строка - путь для сохранения файла
//  Фильтр      - Структура - параметры фильтрации (необязательно)
//
// Возвращаемое значение:
//  Булево - успешность экспорта
//
Функция ЭкспортПросрочекВCSV(ПутьКФайлу, Фильтр = Неопределено) Экспорт
    
    Попытка
        Отчет = УправлениеВыдачами.ПолучитьОтчетПросрочки(Фильтр);
        
        ТекстCSV = Новый ТекстовыйДокумент;
        
        // Заголовок
        ТекстCSV.ДобавитьСтроку("reader_id;fio;group;book_code;title;author;issue_date;due_date;return_date;days_overdue");
        
        // Данные
        Для Каждого Запись Из Отчет.items Цикл
            СтрокаCSV = СформироватьСтрокуCSV(Новый Массив);
            СтрокаCSV = Запись.reader_id + ";" +
                        Запись.fio + ";" +
                        Запись.group + ";" +
                        Запись.book_code + ";" +
                        Запись.title + ";" +
                        Запись.author + ";" +
                        Формат(Запись.issue_date, "ДФ=yyyy-MM-dd") + ";" +
                        Формат(Запись.due_date, "ДФ=yyyy-MM-dd") + ";" +
                        ?(ЗначениеЗаполнено(Запись.return_date), Формат(Запись.return_date, "ДФ=yyyy-MM-dd"), "") + ";" +
                        Формат(Запись.days_overdue, "ЧГ=0");
            ТекстCSV.ДобавитьСтроку(СтрокаCSV);
        КонецЦикла;
        
        // Итоговые строки
        ТекстCSV.ДобавитьСтроку("");
        ТекстCSV.ДобавитьСтроку("Итого просрочек;" + Отчет.total_overdue);
        ТекстCSV.ДобавитьСтроку("Всего активных выдач;" + Отчет.total_active_loans);
        ТекстCSV.ДобавитьСтроку("Процент просрочек;" + Формат(Отчет.overdue_percentage, "ЧДЦ=2") + "%");
        ТекстCSV.ДобавитьСтроку("Средняя просрочка (дни);" + Формат(Отчет.average_overdue_days, "ЧДЦ=2"));
        ТекстCSV.ДобавитьСтроку("Медианная просрочка (дни);" + Формат(Отчет.median_overdue_days, "ЧДЦ=2"));
        ТекстCSV.ДобавитьСтроку("Дата формирования;" + Формат(Отчет.generated_at, "ДФ=yyyy-MM-dd HH:mm:ss"));
        
        ТекстCSV.Записать(ПутьКФайлу, КодировкаТекста.UTF8);
        
        Возврат Истина;
        
    Исключение
        ВызватьИсключение "Ошибка экспорта: " + ОписаниеОшибки();
    КонецПопытки;
    
КонецФункции

// Экспортирует книги в CSV
//
// Параметры:
//  ПутьКФайлу - Строка - путь для сохранения файла
//
// Возвращаемое значение:
//  Булево - успешность экспорта
//
Функция ЭкспортКнигВCSV(ПутьКФайлу) Экспорт
    
    Попытка
        Книги = РаботаСКнигами.ПолучитьСписокКниг();
        
        ТекстCSV = Новый ТекстовыйДокумент;
        ТекстCSV.ДобавитьСтроку("book_code;title;author;year;udk;description;publisher;pages;isbn;is_available");
        
        Для Каждого Книга Из Книги Цикл
            СтрокаCSV = Книга.book_code + ";" +
                        ЭкранироватьДляCSV(Книга.title) + ";" +
                        ЭкранироватьДляCSV(Книга.author) + ";" +
                        Формат(Книга.year, "ЧГ=0") + ";" +
                        Книга.udk + ";" +
                        ЭкранироватьДляCSV(Книга.description) + ";" +
                        ЭкранироватьДляCSV(Книга.publisher) + ";" +
                        Формат(Книга.pages, "ЧГ=0") + ";" +
                        Книга.isbn + ";" +
                        ?(Книга.is_available, "1", "0");
            ТекстCSV.ДобавитьСтроку(СтрокаCSV);
        КонецЦикла;
        
        ТекстCSV.Записать(ПутьКФайлу, КодировкаТекста.UTF8);
        
        Возврат Истина;
        
    Исключение
        ВызватьИсключение "Ошибка экспорта: " + ОписаниеОшибки();
    КонецПопытки;
    
КонецФункции

