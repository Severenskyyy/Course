#КонецОбласти

#Область ИнтеграцияСFastAPI

// Отправляет данные на FastAPI сервер
//
// Параметры:
//  Endpoint    - Строка - путь API (например, "/api/import-export/books")
//  Данные      - Строка - данные в формате JSON или CSV
//  Метод       - Строка - HTTP метод (POST, PUT и т.д.)
//
// Возвращаемое значение:
//  Структура:
//      * Успешно   - Булево
//      * Код       - Число - HTTP код ответа
//      * Данные    - Строка - тело ответа
//      * Ошибка    - Строка - описание ошибки
//
Функция ОтправитьНаСервер(Endpoint, Данные, Метод = "POST") Экспорт
    
    Результат = Новый Структура;
    Результат.Вставить("success", Ложь);
    Результат.Вставить("status_code", 0);
    Результат.Вставить("data", "");
    Результат.Вставить("error", "");
    
    Попытка
        АдресСервера = ПолучитьАдресСервераAPI();
        
        HTTPСоединение = Новый HTTPСоединение(АдресСервера, 8000);
        HTTPЗапрос = Новый HTTPЗапрос(Endpoint);
        HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
        HTTPЗапрос.Заголовки.Вставить("Accept", "application/json");
        
        // Добавляем токен авторизации если есть
        Токен = ПолучитьТокенАвторизации();
        Если ЗначениеЗаполнено(Токен) Тогда
            HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + Токен);
        КонецЕсли;
        
        HTTPЗапрос.УстановитьТелоИзСтроки(Данные);
        
        Если ВРег(Метод) = "POST" Тогда
            HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
        ИначеЕсли ВРег(Метод) = "PUT" Тогда
            HTTPОтвет = HTTPСоединение.Записать(HTTPЗапрос);
        ИначеЕсли ВРег(Метод) = "DELETE" Тогда
            HTTPОтвет = HTTPСоединение.Удалить(HTTPЗапрос);
        Иначе
            HTTPОтвет = HTTPСоединение.Получить(HTTPЗапрос);
        КонецЕсли;
        
        Результат.status_code = HTTPОтвет.КодСостояния;
        Результат.data = HTTPОтвет.ПолучитьТелоКакСтроку();
        Результат.success = HTTPОтвет.КодСостояния >= 200 И HTTPОтвет.КодСостояния < 300;
        
    Исключение
        Результат.error = ОписаниеОшибки();
    КонецПопытки;
    
    Возврат Результат;
    
КонецФункции

// Получает данные с FastAPI сервера
//
// Параметры:
//  Endpoint - Строка - путь API
//
// Возвращаемое значение:
//  Структура - результат запроса
//
Функция ПолучитьССервера(Endpoint) Экспорт
    
    Результат = Новый Структура;
    Результат.Вставить("success", Ложь);
    Результат.Вставить("status_code", 0);
    Результат.Вставить("data", "");
    Результат.Вставить("error", "");
    
    Попытка
        АдресСервера = ПолучитьАдресСервераAPI();
        
        HTTPСоединение = Новый HTTPСоединение(АдресСервера, 8000);
        HTTPЗапрос = Новый HTTPЗапрос(Endpoint);
        HTTPЗапрос.Заголовки.Вставить("Accept", "application/json");
        
        Токен = ПолучитьТокенАвторизации();
        Если ЗначениеЗаполнено(Токен) Тогда
            HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + Токен);
        КонецЕсли;
        
        HTTPОтвет = HTTPСоединение.Получить(HTTPЗапрос);
        
        Результат.status_code = HTTPОтвет.КодСостояния;
        Результат.data = HTTPОтвет.ПолучитьТелоКакСтроку();
        Результат.success = HTTPОтвет.КодСостояния >= 200 И HTTPОтвет.КодСостояния < 300;
        
    Исключение
        Результат.error = ОписаниеОшибки();
    КонецПопытки;
    
    Возврат Результат;
    
КонецФункции

// Синхронизирует книги с FastAPI сервером
