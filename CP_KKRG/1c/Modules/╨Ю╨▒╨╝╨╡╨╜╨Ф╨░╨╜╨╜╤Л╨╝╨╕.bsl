// Получает отчёт о просрочках с FastAPI сервера
//
// Возвращаемое значение:
//  Структура - отчёт о просрочках
//
Функция ПолучитьОтчетПросрочекССервера() Экспорт
    
    Ответ = ПолучитьССервера("/api/reports/overdue");
    
    Если НЕ Ответ.success Тогда
        Возврат Ответ;
    КонецЕсли;
    
    // Парсим JSON
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(Ответ.data);
    Отчет = ПрочитатьJSON(ЧтениеJSON);
    
    Ответ.Вставить("report", Отчет);
    
    Возврат Ответ;
    
КонецФункции

