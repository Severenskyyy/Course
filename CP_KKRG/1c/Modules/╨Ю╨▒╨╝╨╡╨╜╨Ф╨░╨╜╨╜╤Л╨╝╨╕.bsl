Функция РазобратьСтрокуCSV(Строка, Разделитель = ";")
    
    Поля = Новый Массив;
    ТекущееПоле = "";
    ВКавычках = Ложь;
    
    Для Позиция = 1 По СтрДлина(Строка) Цикл
        Символ = Сред(Строка, Позиция, 1);
        
        Если Символ = """" Тогда
            ВКавычках = НЕ ВКавычках;
        ИначеЕсли Символ = Разделитель И НЕ ВКавычках Тогда
            Поля.Добавить(ТекущееПоле);
            ТекущееПоле = "";
        Иначе
            ТекущееПоле = ТекущееПоле + Символ;
        КонецЕсли;
    КонецЦикла;
    
    Поля.Добавить(ТекущееПоле);
    
    Возврат Поля;
    
КонецФункции

Функция ЭкранироватьДляCSV(Значение)
    
    Если НЕ ЗначениеЗаполнено(Значение) Тогда
        Возврат "";
    КонецЕсли;
    
    Результат = СтрЗаменить(Строка(Значение), """", """""");
    
    Если СтрНайти(Результат, ";") > 0 ИЛИ СтрНайти(Результат, """") > 0 ИЛИ СтрНайти(Результат, Символы.ПС) > 0 Тогда
        Результат = """" + Результат + """";
    КонецЕсли;
    
    Возврат Результат;
    
КонецФункции

Функция ПрочитатьДатуISO(СтрокаДаты)
    
    Если НЕ ЗначениеЗаполнено(СтрокаДаты) Тогда
        Возврат Дата(1,1,1);
    КонецЕсли;
    
    // Формат: YYYY-MM-DD или YYYY-MM-DDTHH:MM:SS
    СтрокаДаты = СокрЛП(СтрокаДаты);
    
    Попытка
        Год = Число(Лев(СтрокаДаты, 4));
        Месяц = Число(Сред(СтрокаДаты, 6, 2));
        День = Число(Сред(СтрокаДаты, 9, 2));
        
        Час = 0; Минута = 0; Секунда = 0;
        
        Если СтрДлина(СтрокаДаты) > 10 Тогда
            Час = Число(Сред(СтрокаДаты, 12, 2));
            Минута = Число(Сред(СтрокаДаты, 15, 2));
            Если СтрДлина(СтрокаДаты) >= 19 Тогда
                Секунда = Число(Сред(СтрокаДаты, 18, 2));
            КонецЕсли;
        КонецЕсли;
        
        Возврат Дата(Год, Месяц, День, Час, Минута, Секунда);
        
    Исключение
        Возврат Дата(1,1,1);
    КонецПопытки;
    
КонецФункции

Функция ВыдачаСуществует(НомерВыдачи)
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   ВыдачаКниги.Ссылка
        |ИЗ
        |   Документ.ВыдачаКниги КАК ВыдачаКниги
        |ГДЕ
        |   ВыдачаКниги.Номер = &Номер";
    Запрос.УстановитьПараметр("Номер", НомерВыдачи);
    
    Возврат НЕ Запрос.Выполнить().Пустой();
    
КонецФункции

Процедура СоздатьВыдачуИзИмпорта(НомерВыдачи, Книга, Читатель, ДатаВыдачи, ДатаВозвратаПлан, ДатаВозврата)
    
    // Создаём документ выдачи
    ДокументВыдачи = Документы.ВыдачаКниги.СоздатьДокумент();
    ДокументВыдачи.Номер = НомерВыдачи;
    ДокументВыдачи.Дата = ДатаВыдачи;
    ДокументВыдачи.Книга = Книга;
    ДокументВыдачи.Читатель = Читатель;
    ДокументВыдачи.ДатаВозвратаПлан = ДатаВозвратаПлан;
    ДокументВыдачи.Комментарий = "Импорт из CSV";
    
    ДокументВыдачи.Записать(РежимЗаписиДокумента.Проведение);
    
    // Если есть дата возврата - создаём возврат
    Если ДатаВозврата <> Дата(1,1,1) Тогда
        ДокументВозврата = Документы.ВозвратКниги.СоздатьДокумент();
        ДокументВозврата.Дата = ДатаВозврата;
        ДокументВозврата.ДокументВыдачи = ДокументВыдачи.Ссылка;
        ДокументВозврата.Книга = Книга;
        ДокументВозврата.Читатель = Читатель;
        ДокументВозврата.ЕстьПросрочка = ДатаВозврата > ДатаВозвратаПлан;
        ДокументВозврата.Комментарий = "Импорт из CSV";
        
        ДокументВозврата.Записать(РежимЗаписиДокумента.Проведение);
    Иначе
        // Книга не возвращена - обновляем доступность
        РаботаСКнигами.УстановитьДоступность(Книга, Ложь);
    КонецЕсли;
    
КонецПроцедуры

